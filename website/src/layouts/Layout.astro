      document.querySelectorAll('.mobile-nav-item').forEach(el => {
        const dp = el.getAttribute('data-path') || '';
        if (path === dp || path === dp + '/' || (dp !== '/' && path.startsWith(dp))) {
          el.classList.add('active');
        }
      });
    </script>

    <!-- PWA Install Banner -->
    <div id="pwa-install-banner" class="pwa-install-banner" style="display:none;">
      <div class="pwa-install-inner">
        <div class="pwa-install-text">
          <span class="pwa-install-icon">📲</span>
          <div>
            <strong>FluentGe აპის დამატება</strong>
            <span class="pwa-install-sub">დააინსტალირე მთავარ ეკრანზე</span>
          </div>
        </div>
        <div class="pwa-install-actions">
          <button id="pwa-install-btn" class="pwa-install-yes">დამატება</button>
          <button id="pwa-dismiss-btn" class="pwa-install-no">არა</button>
        </div>
      </div>
    </div>
    <script>
      // Service Worker + PWA Install Prompt
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      }
      (function() {
        let deferredPrompt = null;
        const banner = document.getElementById('pwa-install-banner');
        const installBtn = document.getElementById('pwa-install-btn');
        const dismissBtn = document.getElementById('pwa-dismiss-btn');
        if (!banner || localStorage.getItem('fluentge-pwa-dismissed')) return;
        
        window.addEventListener('beforeinstallprompt', function(e) {
          e.preventDefault();
          deferredPrompt = e;
          banner.style.display = 'block';
        });
        
        installBtn?.addEventListener('click', function() {
          if (deferredPrompt) {
            deferredPrompt.prompt();
            deferredPrompt.userChoice.then(function() { banner.style.display = 'none'; });
            deferredPrompt = null;
          }
        });
        
        dismissBtn?.addEventListener('click', function() {
          banner.style.display = 'none';
          localStorage.setItem('fluentge-pwa-dismissed', '1');
        });

        // iOS: show manual instructions
        if (/iPhone|iPad/.test(navigator.userAgent) && !navigator.standalone) {
          banner.style.display = 'block';
          installBtn.textContent = 'გასაგებია';
          var sub = banner.querySelector('.pwa-install-sub');
          if (sub) sub.textContent = 'Safari → Share → Add to Home Screen';
          installBtn.addEventListener('click', function() {
            banner.style.display = 'none';
            localStorage.setItem('fluentge-pwa-dismissed', '1');
          });
        }
      })();
    </script>

