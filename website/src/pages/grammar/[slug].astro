---
import Layout from '../../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  const grammarDir = path.resolve('..', 'content', 'grammar');
  const files = fs.readdirSync(grammarDir).filter(f => f.endsWith('.json')).sort();
  const allLessons = files.map(f => JSON.parse(fs.readFileSync(path.join(grammarDir, f), 'utf-8')));
  return allLessons.map((lesson, i) => {
    const nextLesson = i < allLessons.length - 1 ? { slug: allLessons[i+1].slug, title_ka: allLessons[i+1].title_ka, level: allLessons[i+1].level } : null;
    const prevLesson = i > 0 ? { slug: allLessons[i-1].slug, title_ka: allLessons[i-1].title_ka, level: allLessons[i-1].level } : null;
    return { params: { slug: lesson.slug }, props: { lesson, nextLesson, prevLesson } };
  });
}

const { lesson, nextLesson, prevLesson } = Astro.props;
const FREE_GRAMMAR_SLUGS = ['to-be', 'articles', 'plural-nouns', 'present-simple', 'present-continuous', 'subject-pronouns', 'possessive-adjectives', 'prepositions-of-place'];
const isFree = FREE_GRAMMAR_SLUGS.includes(lesson.slug);

// Grammar → Flashcard deck mapping for interconnection
const grammarToDecks: Record<string, {deck: string, label: string, emoji: string}[]> = {
  'to-be': [
    {deck: 'greetings-basics', label: 'მისალმებები', emoji: '👋'},
    {deck: 'family-people', label: 'ოჯახი და ხალხი', emoji: '👨‍👩‍👧'},
    {deck: 'jobs-professions', label: 'პროფესიები', emoji: '💼'},
  ],
  'articles': [
    {deck: 'daily-routines', label: 'ყოველდღიური რუტინა', emoji: '☀️'},
    {deck: 'food-drink', label: 'საჭმელი და სასმელი', emoji: '🍕'},
    {deck: 'furniture-rooms', label: 'ავეჯი და ოთახები', emoji: '🏠'},
  ],
  'plural-nouns': [
    {deck: 'animals', label: 'ცხოველები', emoji: '🐾'},
    {deck: 'body-parts', label: 'სხეულის ნაწილები', emoji: '🦴'},
    {deck: 'clothes-fashion', label: 'ტანსაცმელი', emoji: '👕'},
  ],
  'present-simple': [
    {deck: 'daily-routines', label: 'ყოველდღიური რუტინა', emoji: '☀️'},
    {deck: 'verbs-common', label: 'ხშირი ზმნები', emoji: '🏃'},
    {deck: 'hobbies-free-time', label: 'ჰობი', emoji: '🎨'},
  ],
  'present-continuous': [
    {deck: 'verbs-common', label: 'ხშირი ზმნები', emoji: '🏃'},
    {deck: 'sports-fitness', label: 'სპორტი', emoji: '⚽'},
    {deck: 'daily-routines', label: 'ყოველდღიური რუტინა', emoji: '☀️'},
  ],
  'subject-pronouns': [
    {deck: 'greetings-basics', label: 'მისალმებები', emoji: '👋'},
    {deck: 'family-people', label: 'ოჯახი', emoji: '👨‍👩‍👧'},
  ],
  'possessive-adjectives': [
    {deck: 'family-people', label: 'ოჯახი', emoji: '👨‍👩‍👧'},
    {deck: 'body-parts', label: 'სხეულის ნაწილები', emoji: '🦴'},
    {deck: 'home-housing', label: 'სახლი', emoji: '🏠'},
  ],
  'prepositions-of-place': [
    {deck: 'furniture-rooms', label: 'ავეჯი და ოთახები', emoji: '🏠'},
    {deck: 'directions-places', label: 'მიმართულებები', emoji: '🧭'},
    {deck: 'prepositions-conjunctions', label: 'წინდებულები', emoji: '📍'},
  ],
  'there-is-are': [
    {deck: 'furniture-rooms', label: 'ავეჯი და ოთახები', emoji: '🏠'},
    {deck: 'home-housing', label: 'სახლი', emoji: '🏡'},
    {deck: 'colors-shapes', label: 'ფერები და ფორმები', emoji: '🎨'},
  ],
  'can-cant': [
    {deck: 'sports-fitness', label: 'სპორტი', emoji: '⚽'},
    {deck: 'hobbies-free-time', label: 'ჰობი', emoji: '🎨'},
    {deck: 'verbs-common', label: 'ხშირი ზმნები', emoji: '🏃'},
  ],
};
const relatedDecks = grammarToDecks[lesson.slug] || [
  {deck: 'top-2000-words', label: 'ტოპ 2000 სიტყვა', emoji: '📚'},
  {deck: 'verbs-common', label: 'ხშირი ზმნები', emoji: '🏃'},
];
---

<Layout title={`${lesson.title_ka} — FluentGe`}>
  <section class="max-w-3xl mx-auto px-4 py-16">
    <!-- Header -->
    <a href="/grammar/" class="text-[#C8C8C0] hover:underline text-sm mb-6 inline-block">← გრამატიკა</a>

    <!-- Review Mode Banner -->
    <div id="review-banner" class="hidden mb-6 p-4 rounded-xl bg-gradient-to-r from-purple-600/20 to-indigo-600/20 border border-purple-500/30">
      <div class="flex items-center gap-3">
        <span class="text-2xl">🔄</span>
        <div>
          <div class="font-bold text-purple-300">გამეორების რეჟიმი</div>
          <div class="text-sm text-purple-300/70">ადრე გავლილი გაკვეთილის გამეორება</div>
        </div>
      </div>
    </div>
    <div class="flex items-center gap-3 mb-2">
      <span class={`px-3 py-1 rounded-full text-xs font-bold ${lesson.level === 'A1' ? 'bg-green-500/20 text-green-400' : lesson.level === 'A2' ? 'bg-blue-500/20 text-blue-400' : lesson.level === 'B1' ? 'bg-yellow-500/20 text-yellow-400' : lesson.level === 'B2' ? 'bg-orange-500/20 text-orange-400' : 'bg-purple-500/20 text-purple-400'}`}>{lesson.level}</span>
      <span class="text-[#6B6B65] text-sm">გაკვეთილი #{lesson.id}</span>
    </div>
    <h1 class="text-3xl font-bold mb-1">{lesson.title_ka}</h1>
    <p class="text-[#6B6B65] mb-8">{lesson.title_en}</p>

    <!-- Lesson Content (hidden for non-premium if lesson is premium) -->
    <div id="lesson-content" class={isFree ? '' : 'hidden'}>
    <!-- Explanation -->
    <div class="bg-[#242426] border border-[#2E2E30] rounded-xl p-6 mb-8">
      <h2 class="text-xl font-bold mb-4">📚 ახსნა</h2>
      <div class="text-[#cbd5e1] leading-relaxed whitespace-pre-line">{lesson.explanation_ka}</div>
    </div>

    <!-- Examples -->
    <div class="bg-[#242426] border border-[#2E2E30] rounded-xl p-6 mb-8">
      <h2 class="text-xl font-bold mb-4">💡 მაგალითები</h2>
      <div class="space-y-3">
        {lesson.examples.map((ex: {en: string, ka: string}) => (
          <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-4 py-2 border-b border-white/5 last:border-0">
            <span class="font-medium text-[#C8C8C0]">{ex.en}</span>
            <span class="text-[#6B6B65]">— {ex.ka}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Common Mistakes -->
    <div class="bg-red-500/5 border border-red-500/20 rounded-xl p-6 mb-8">
      <h2 class="text-xl font-bold mb-4 text-red-400">⚠️ ხშირი შეცდომები</h2>
      <p class="text-[#cbd5e1] leading-relaxed whitespace-pre-line">{lesson.common_mistakes_ka}</p>
    </div>

    <!-- Exercises -->
    <div class="bg-[#242426] border border-[#2E2E30] rounded-2xl overflow-hidden" id="exercises-section">
      <!-- Progress bar (top) -->
      <div class="px-6 pt-5 pb-0">
        <div class="flex items-center gap-3 mb-2">
          <button id="exercise-close-btn" class="text-[#6B6B65] hover:text-red-400 transition-colors text-lg" title="დახურვა">✕</button>
          <div class="flex-1 h-4 bg-[#1C1C1E] rounded-full overflow-hidden">
            <div id="exercise-progress-bar" class="h-full bg-gradient-to-r from-green-400 to-emerald-500 rounded-full transition-all duration-500 relative" style="width:0%">
              <div class="absolute inset-0 rounded-full bg-gradient-to-b from-white/20 to-transparent"></div>
            </div>
          </div>
          <span id="exercise-counter" class="text-sm font-bold text-[#6B6B65] tabular-nums min-w-[3rem] text-right">0/0</span>
        </div>
      </div>

      <div id="exercise-container" class="px-6 py-6"></div>

      <!-- Bottom feedback bar -->
      <div id="exercise-feedback-bar" class="hidden">
        <div id="feedback-inner" class="px-6 py-4 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <span id="feedback-icon" class="text-2xl"></span>
            <div>
              <p id="feedback-title" class="font-bold text-lg"></p>
              <p id="feedback-detail" class="text-sm opacity-80"></p>
            </div>
          </div>
          <button id="continue-btn" class="font-bold uppercase tracking-wide px-8 py-3 rounded-xl border-b-4 active:border-b-0 active:mt-[4px] transition-all text-white">გაგრძელება</button>
        </div>
      </div>

      <!-- Result screen -->
      <div id="score-container" class="hidden px-6 py-10 text-center">
        <div class="text-6xl mb-4" id="score-emoji"></div>
        <h2 class="text-2xl font-bold mb-2">გაკვეთილი დასრულდა!</h2>
        <p class="text-[#6B6B65] mb-8" id="score-msg"></p>
        <div class="grid grid-cols-3 gap-4 max-w-sm mx-auto mb-8">
          <div class="bg-[#1C1C1E] rounded-xl p-4 border-b-4 border-green-500/30">
            <div class="text-2xl font-bold text-green-400" id="score-correct">0</div>
            <div class="text-xs text-[#6B6B65]">სწორი</div>
          </div>
          <div class="bg-[#1C1C1E] rounded-xl p-4 border-b-4 border-sky-500/30">
            <div class="text-2xl font-bold text-sky-400" id="score-pct">0%</div>
            <div class="text-xs text-[#6B6B65]">სიზუსტე</div>
          </div>
          <div class="bg-[#1C1C1E] rounded-xl p-4 border-b-4 border-amber-500/30">
            <div class="text-2xl font-bold text-amber-400" id="score-xp">0</div>
            <div class="text-xs text-[#6B6B65]">XP ⭐</div>
          </div>
        </div>
        <div class="flex gap-3 justify-center">
          <button id="retry-btn" class="bg-[#2E2E30] hover:bg-[#3E3E40] text-white px-6 py-3 rounded-xl font-bold border-b-4 border-[#1C1C1E] active:border-b-0 active:mt-[4px] transition-all">🔄 თავიდან</button>
          <a href="/grammar/" class="bg-gradient-to-r from-sky-400 to-sky-500 hover:from-sky-500 hover:to-sky-600 text-white px-6 py-3 rounded-xl font-bold border-b-4 border-sky-600 active:border-b-0 active:mt-[4px] transition-all inline-block">📚 გრამატიკა</a>
        </div>
      </div>
    </div>
    </div>

    <!-- Premium locked overlay -->
    <div id="premium-lock" class={isFree ? 'hidden' : 'mt-8 text-center'}>
      <div class="bg-gradient-to-r from-amber-500/10 to-orange-500/10 border border-amber-500/20 rounded-2xl p-12">
        <div class="text-6xl mb-4">🔒</div>
        <h2 class="text-2xl font-bold mb-3">ეს გაკვეთილი პრემიუმია</h2>
        <p class="text-[#6B6B65] mb-6 max-w-md mx-auto">გახსენი ყველა გრამატიკის გაკვეთილი პრემიუმ გეგმით.</p>
        <a href="/premium/" class="inline-block bg-[var(--color-primary)] hover:bg-[var(--color-primary-hover)] text-white font-bold py-3 px-8 rounded-xl text-lg transition-colors">
          🚀 დაიწყე პრემიუმი
        </a>
      </div>
    </div>

    <!-- Related Flashcard Decks -->
    <div id="related-decks-section" class={isFree ? 'mt-8' : 'hidden mt-8'}>
      <div class="bg-gradient-to-r from-sky-500/5 to-indigo-500/5 border border-sky-500/15 rounded-2xl p-6">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-xl">📝</span>
          <h2 class="text-lg font-bold">დაკავშირებული ფლეშქარდები</h2>
        </div>
        <p class="text-[#6B6B65] text-sm mb-4">ისწავლე ლექსიკა, რომელიც ამ გაკვეთილთან არის დაკავშირებული:</p>
        <div class="grid gap-2 sm:grid-cols-{relatedDecks.length > 2 ? '3' : '2'}">
          {relatedDecks.map(d => (
            <a href={`/flashcards/?deck=${d.deck}`} class="flex items-center gap-3 bg-[#242426] hover:bg-[#2E2E30] border border-[#2E2E30] rounded-xl px-4 py-3 transition-all hover:scale-[1.02] hover:border-sky-500/30">
              <span class="text-lg">{d.emoji}</span>
              <span class="text-sm font-medium">{d.label}</span>
              <span class="text-[#6B6B65] ml-auto text-xs">→</span>
            </a>
          ))}
        </div>
        <div class="mt-4 pt-3 border-t border-white/5 flex items-center justify-between">
          <span class="text-xs text-[#6B6B65]">🎮 სიტყვები + გრამატიკა = სწრაფი სწავლა!</span>
          <a href="/flashcards/" class="text-xs text-sky-400 hover:text-sky-300 transition-colors">ყველა კატეგორია →</a>
        </div>
      </div>
    </div>

    <!-- Next/Previous Lesson Navigation -->
    <div id="next-lesson-section" class={isFree ? 'mt-4' : 'hidden mt-4'}>
      <div class="flex gap-3">
        {prevLesson && (
          <a href={`/grammar/${prevLesson.slug}/`} class="flex-1 flex items-center gap-3 bg-[#242426] hover:bg-[#2E2E30] border border-[#2E2E30] rounded-xl px-4 py-3 transition-all hover:scale-[1.02]">
            <span class="text-[#6B6B65]">←</span>
            <div class="min-w-0">
              <p class="text-xs text-[#6B6B65]">წინა გაკვეთილი</p>
              <p class="text-sm font-medium truncate">{prevLesson.title_ka}</p>
            </div>
          </a>
        )}
        {nextLesson && (
          <a href={`/grammar/${nextLesson.slug}/`} class="flex-1 flex items-center justify-end gap-3 bg-[#242426] hover:bg-[#2E2E30] border border-[#2E2E30] rounded-xl px-4 py-3 transition-all hover:scale-[1.02] text-right">
            <div class="min-w-0">
              <p class="text-xs text-[#6B6B65]">შემდეგი გაკვეთილი</p>
              <p class="text-sm font-medium truncate">{nextLesson.title_ka}</p>
            </div>
            <span class="text-[#6B6B65]">→</span>
          </a>
        )}
      </div>
    </div>

    <!-- Mark as learned -->
    <div id="mark-section" class={isFree ? 'mt-8 text-center' : 'hidden mt-8 text-center'}>
      <button id="mark-grammar-btn" data-title={lesson.title_en} class="inline-flex items-center gap-2 bg-[#242426] hover:bg-[#2E2E30] border-2 border-[#6B6B65] rounded-xl px-6 py-3 font-semibold transition-colors">
        <span id="mark-grammar-icon">✓</span>
        <span id="mark-grammar-text">მონიშნე ნასწავლად</span>
      </button>
    </div>
  </section>

  <script is:inline src="/js/gamification-bridge.js"></script>
  <script is:inline>
    (function() {
      // Unlock premium grammar for premium users
      if (localStorage.getItem('fluentge-premium') === 'true') {
        var lc = document.getElementById('lesson-content');
        if (lc) lc.classList.remove('hidden');
        var pl = document.getElementById('premium-lock');
        if (pl) pl.classList.add('hidden');
        var ms = document.getElementById('mark-section');
        if (ms) ms.classList.remove('hidden');
        var rd = document.getElementById('related-decks-section');
        if (rd) rd.classList.remove('hidden');
        var nl = document.getElementById('next-lesson-section');
        if (nl) nl.classList.remove('hidden');
      }
      const btn = document.getElementById('mark-grammar-btn');
      if (!btn) return;
      const title = btn.dataset.title;
      const stored = JSON.parse(localStorage.getItem('fluentge-learned-grammar') || '[]');
      if (stored.includes(title)) {
        btn.classList.remove('border-[#6B6B65]');
        btn.classList.add('border-green-400', 'text-green-400', 'bg-green-400/10');
        document.getElementById('mark-grammar-text').textContent = 'ნასწავლია ✅';
      }
      btn.addEventListener('click', function() {
        const items = JSON.parse(localStorage.getItem('fluentge-learned-grammar') || '[]');
        if (items.includes(title)) {
          items.splice(items.indexOf(title), 1);
          btn.classList.remove('border-green-400', 'text-green-400', 'bg-green-400/10');
          btn.classList.add('border-[#6B6B65]');
          document.getElementById('mark-grammar-text').textContent = 'მონიშნე ნასწავლად';
        } else {
          items.push(title);
          btn.classList.add('border-green-400', 'text-green-400', 'bg-green-400/10');
          btn.classList.remove('border-[#6B6B65]');
          document.getElementById('mark-grammar-text').textContent = 'ნასწავლია ✅';
        }
        localStorage.setItem('fluentge-learned-grammar', JSON.stringify(items));
      });
    })();
  </script>

  <script define:vars={{ exercises: lesson.exercises, isFree, lessonSlug: lesson.slug }}>
    // Review mode detection
    var isReviewMode = window.location.search.includes('review=1');
    if (isReviewMode) {
      // Show review banner
      var banner = document.getElementById('review-banner');
      if (banner) banner.classList.remove('hidden');
      // Unhide lesson content for review
      var lc = document.getElementById('lesson-content');
      if (lc) lc.classList.remove('hidden');
      // Allow exercises even for premium in review mode (they already completed it)
      // Track review date
      try {
        var reviewDates = JSON.parse(localStorage.getItem('fluentge-grammar-reviews') || '{}');
        reviewDates[lessonSlug] = new Date().toISOString();
        localStorage.setItem('fluentge-grammar-reviews', JSON.stringify(reviewDates));
      } catch(e) {}
      // Shuffle exercises
      for (var i = exercises.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var temp = exercises[i];
        exercises[i] = exercises[j];
        exercises[j] = temp;
      }
      // Auto-scroll to exercises
      setTimeout(function() {
        var exSection = document.getElementById('exercises-section');
        if (exSection) exSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 500);
    }

    // Sound feedback — resume AudioContext on first user click (required by browsers)
    let audioCtx = null;
    function getCtx() {
      if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      if (audioCtx.state === 'suspended') audioCtx.resume();
      return audioCtx;
    }
    function playCorrectSound() {
      try {
        const ctx = getCtx();
        const o = ctx.createOscillator();
        const g = ctx.createGain();
        o.connect(g);
        g.connect(ctx.destination);
        g.gain.setValueAtTime(0.15, ctx.currentTime);
        o.type = 'sine';
        o.frequency.setValueAtTime(523, ctx.currentTime);
        o.frequency.setValueAtTime(659, ctx.currentTime + 0.1);
        g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.3);
        o.start(ctx.currentTime);
        o.stop(ctx.currentTime + 0.35);
      } catch(e) { console.log('sound error', e); }
    }
    function playWrongSound() {
      try {
        const ctx = getCtx();
        const o = ctx.createOscillator();
        const g = ctx.createGain();
        o.connect(g);
        g.connect(ctx.destination);
        g.gain.setValueAtTime(0.12, ctx.currentTime);
        o.type = 'sine';
        o.frequency.setValueAtTime(330, ctx.currentTime);
        o.frequency.setValueAtTime(262, ctx.currentTime + 0.15);
        g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.25);
        o.start(ctx.currentTime);
        o.stop(ctx.currentTime + 0.3);
      } catch(e) { console.log('sound error', e); }
    }

    if (!isFree && !isReviewMode) { /* skip exercises for premium lessons */ }
    else {
    let current = 0;
    let score = 0;
    let answered = false;
    let sessionXP = 0;
    let streak = 0;

    const container = document.getElementById('exercise-container');
    const scoreContainer = document.getElementById('score-container');
    const feedbackBar = document.getElementById('exercise-feedback-bar');
    const feedbackInner = document.getElementById('feedback-inner');
    const feedbackIcon = document.getElementById('feedback-icon');
    const feedbackTitle = document.getElementById('feedback-title');
    const feedbackDetail = document.getElementById('feedback-detail');
    const continueBtn = document.getElementById('continue-btn');
    const progressBar = document.getElementById('exercise-progress-bar');
    const counterEl = document.getElementById('exercise-counter');

    // Initialize gamification
    if (window.FluentGe) {
      FluentGe.createXPCounter();
      FluentGe.updateXPCounter(FluentGe.getTotalXP());
      FluentGe.startTimer();
    }

    // Close button
    document.getElementById('exercise-close-btn').addEventListener('click', function() {
      if (confirm('ნამდვილად გსურს გაკვეთილის დატოვება?')) {
        document.getElementById('exercises-section').scrollIntoView({behavior:'smooth', block:'start'});
      }
    });

    // Continue button
    continueBtn.addEventListener('click', function() {
      feedbackBar.classList.add('hidden');
      current++;
      render();
    });

    // Keyboard: Enter/Space to continue
    document.addEventListener('keydown', function(e) {
      if ((e.key === 'Enter' || e.key === ' ') && answered && !feedbackBar.classList.contains('hidden')) {
        e.preventDefault();
        continueBtn.click();
      }
    });

    function updateProgress() {
      const pct = exercises.length > 0 ? (current / exercises.length) * 100 : 0;
      progressBar.style.width = pct + '%';
      counterEl.textContent = current + '/' + exercises.length;
    }

    function showFeedback(correct, correctAnswer) {
      feedbackBar.classList.remove('hidden');
      if (correct) {
        feedbackInner.className = 'px-6 py-4 flex items-center justify-between bg-green-500/15 border-t-2 border-green-500';
        feedbackIcon.textContent = '✅';
        feedbackTitle.textContent = 'სწორია!';
        feedbackTitle.className = 'font-bold text-lg text-green-400';
        feedbackDetail.textContent = streak > 1 ? '🔥 ' + streak + ' ზედიზედ!' : 'შესანიშნავი!';
        feedbackDetail.className = 'text-sm text-green-400/70';
        continueBtn.className = 'font-bold uppercase tracking-wide px-8 py-3 rounded-xl border-b-4 active:border-b-0 active:mt-[4px] transition-all text-white bg-green-500 border-green-600 hover:bg-green-600';
      } else {
        feedbackInner.className = 'px-6 py-4 flex items-center justify-between bg-red-500/15 border-t-2 border-red-500';
        feedbackIcon.textContent = '❌';
        feedbackTitle.textContent = 'არასწორია';
        feedbackTitle.className = 'font-bold text-lg text-red-400';
        feedbackDetail.textContent = 'სწორი პასუხი: ' + correctAnswer;
        feedbackDetail.className = 'text-sm text-red-400/70';
        continueBtn.className = 'font-bold uppercase tracking-wide px-8 py-3 rounded-xl border-b-4 active:border-b-0 active:mt-[4px] transition-all text-white bg-red-500 border-red-600 hover:bg-red-600';
      }
    }

    function render() {
      updateProgress();
      if (current >= exercises.length) {
        container.classList.add('hidden');
        feedbackBar.classList.add('hidden');
        scoreContainer.classList.remove('hidden');
        const pct = Math.round((score / exercises.length) * 100);
        // Complete progress bar
        progressBar.style.width = '100%';
        progressBar.classList.remove('from-green-400', 'to-emerald-500');
        progressBar.classList.add('from-amber-400', 'to-yellow-500');
        counterEl.textContent = exercises.length + '/' + exercises.length;
        // Bonus XP
        if (window.FluentGe) {
          if (pct >= 50) {
            var bonus = pct >= 80 ? 50 : 25;
            var br = FluentGe.addXP(bonus);
            sessionXP += bonus;
            FluentGe.updateXPCounter(br.newTotal);
            if (br.levelUp) FluentGe.showLevelUp(br.newLevel);
          }
          FluentGe.updateStreak();
          var mins = FluentGe.stopTimer();
          FluentGe.addStudyTime(mins);
          var slug = window.location.pathname.split('/grammar/')[1];
          if (slug) FluentGe.markGrammarComplete(slug.replace(/\/$/, ''));
        }
        document.getElementById('score-emoji').textContent = pct >= 80 ? '🏆' : pct >= 50 ? '👏' : '💪';
        document.getElementById('score-correct').textContent = score + '/' + exercises.length;
        document.getElementById('score-pct').textContent = pct + '%';
        document.getElementById('score-xp').textContent = '+' + sessionXP;
        document.getElementById('score-msg').textContent = pct >= 80 ? 'შესანიშნავი შედეგი! 🎉' : pct >= 50 ? 'კარგი მუშაობა!' : 'კიდევ სცადე, უკეთესად შეძლებ!';
        return;
      }
      answered = false;
      const ex = exercises[current];
      const isMulti = ex.type === 'multiple-choice';
      const letters = ['A', 'B', 'C', 'D', 'E', 'F'];
      
      let html = '';
      if (isMulti) {
        html += `<p class="text-xl font-bold mb-6 leading-relaxed">${ex.question}</p>`;
      } else {
        html += `<p class="text-xl font-bold mb-6 leading-relaxed">${ex.question.replace('___', '<span class="inline-block min-w-[80px] border-b-2 border-sky-400 text-sky-400 text-center mx-1">______</span>')}</p>`;
      }
      
      html += `<div class="grid gap-3">`;
      ex.options.forEach(function(opt, i) {
        html += `<button class="grammar-opt-btn flex items-center gap-3 text-left px-4 py-3.5 rounded-xl border-2 border-[#2E2E30] bg-[#1C1C1E] hover:bg-[#2E2E30] transition-all font-medium cursor-pointer active:scale-[0.98]" data-val="${opt}">
          <span class="w-8 h-8 rounded-lg bg-[#2E2E30] flex items-center justify-center text-sm font-bold text-[#6B6B65] shrink-0">${letters[i] || ''}</span>
          <span>${opt}</span>
        </button>`;
      });
      html += `</div>`;
      
      container.innerHTML = html;
      // Animate in
      container.style.animation = 'none';
      container.offsetHeight;
      container.style.animation = 'grammarSlideIn 0.25s ease-out';

      container.querySelectorAll('.grammar-opt-btn').forEach(function(btn) {
        btn.addEventListener('click', function() { handleAnswer(btn); });
      });
    }

    function handleAnswer(btn) {
      if (answered) return;
      answered = true;
      const val = btn.dataset.val;
      const ex = exercises[current];
      const correct = val === ex.answer;
      if (correct) {
        score++;
        streak++;
        playCorrectSound();
        if (window.FluentGe) {
          var result = FluentGe.addXP(10);
          sessionXP += 10;
          FluentGe.showXPFloat(btn, 10);
          FluentGe.updateXPCounter(result.newTotal);
          if (result.levelUp) FluentGe.showLevelUp(result.newLevel);
        }
      } else {
        streak = 0;
        playWrongSound();
      }

      container.querySelectorAll('.grammar-opt-btn').forEach(function(b) {
        var letter = b.querySelector('span:first-child');
        if (b.dataset.val === ex.answer) {
          b.classList.remove('border-[#2E2E30]', 'bg-[#1C1C1E]');
          b.classList.add('border-green-500', 'bg-green-500/15', 'text-green-400');
          if (letter) { letter.classList.remove('bg-[#2E2E30]', 'text-[#6B6B65]'); letter.classList.add('bg-green-500', 'text-white'); }
        } else if (b === btn && !correct) {
          b.classList.remove('border-[#2E2E30]', 'bg-[#1C1C1E]');
          b.classList.add('border-red-500', 'bg-red-500/15', 'text-red-400');
          if (letter) { letter.classList.remove('bg-[#2E2E30]', 'text-[#6B6B65]'); letter.classList.add('bg-red-500', 'text-white'); }
          b.style.animation = 'wrongShake 0.4s ease-out';
        }
        b.classList.add('pointer-events-none');
      });

      showFeedback(correct, ex.answer);
    }

    document.getElementById('retry-btn').addEventListener('click', function() {
      current = 0; score = 0; sessionXP = 0; streak = 0;
      if (window.FluentGe) FluentGe.startTimer();
      scoreContainer.classList.add('hidden');
      container.classList.remove('hidden');
      progressBar.classList.add('from-green-400', 'to-emerald-500');
      progressBar.classList.remove('from-amber-400', 'to-yellow-500');
      render();
    });

    render();
    }
  </script>
</Layout>
