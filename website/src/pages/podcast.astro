    vocab: ["Menu", "Appetizer", "Main course", "Dessert", "Bill", "Tip", "Reservation", "Waiter"],
    vocabKa: ["მენიუ", "წინაკერძი", "მთავარი კერძი", "დესერტი", "ანგარიში", "ჩაი ფული", "ჯავშანი", "მიმტანი"],
    quiz: [
      { q: "რისთვის მოითხოვა მომხმარებელმა მენიუ?", options: ["ქართულ ენაზე", "ინგლისურ ენაზე", "რუსულ ენაზე", "ფრანგულ ენაზე"], correct: 1 },
