    transcript: [
      { speaker: "Waiter", en: "Good evening. Welcome to our restaurant. Table for two?", ka: "საღამო მშვიდობისა. კეთილი იყოს თქვენი მობრძანება ჩვენს რესტორანში. მაგიდა ორისთვის?" },
      { speaker: "Customer", en: "Yes, please. Do you have the menu in English?", ka: "დიახ, გთხოვთ. გაქვთ მენიუ ინგლისურ ენაზე?" },
