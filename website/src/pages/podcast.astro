      { speaker: "Salesperson", en: "I'll help you find one. The fitting room is over there.", ka: "დაგეხმარებით მოვძებნოთ. სამოსახადი იქ არის." },
      { speaker: "Customer", en: "This looks nice. Is there a discount on this item?", ka: "ეს კარგი ჩანს. არის ფასდაკლება ამ ნივთზე?" },
      { speaker: "Salesperson", en: "Yes, it's 30% off today. Would you like to try it?", ka: "დიახ, დღეს 30% ფასდაკლება. მოვინდომებთ გამოსინჯოთ?" },
      { speaker: "Customer", en: "Perfect! Can I pay with cash or credit card?", ka: "შესანიშნავი! შემიძლია ნაღდი თანხით ან საკრედიტო ბარათით გადავიხადო?" },
      { speaker: "Salesperson", en: "Both are fine. Do you need a receipt for exchange later?", ka: "ორივე შესაძლებელია. გჭირდებათ ქვითარი მოგვიანებით გაცვლისთვის?" },
      { speaker: "Customer", en: "Yes, please. Can I get a refund if it doesn't fit?", ka: "დიახ, გთხოვთ. შემიძლია თანხის დაბრუნება თუ ზომა არ მოვა?" },
