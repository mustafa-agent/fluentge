      { speaker: "Teacher", en: "Georgian has no TH sound. Practice: put your tongue between your teeth and blow air.", ka: "ქართულ ენაში TH ბგერა არ არსებობს. ვარჯიშობა: ენა კბილებს შორის და ჰაერი გაატარეთ." }
    ]
  },
  { id: 34, title: "🎓 Job Interview Preparation", titleKa: "გასაუბრებისთვის მომზადება", icon: "💼", duration: "9:00", file: "/podcast/episode34-job-interview-prep.mp3", free: false,
    vocab: ["Tell me about yourself", "Strengths", "Weaknesses", "Salary", "Experience", "Qualifications", "Why should we hire you?", "Where do you see yourself?"],
    vocabKa: ["მიამბეთ თქვენს შესახებ", "ძლიერი მხარეები", "სუსტი მხარეები", "ხელფასი", "გამოცდილება", "კვალიფიკაცია", "რატომ უნდა დაგიქირაოთ?", "სად ხედავთ თავს?"],
    quiz: [
      { q: "'Tell me about yourself' — რა სტრუქტურით უნდა უპასუხო?", options: ["წარსული, აწმყო, მომავალი", "აწმყო, წარსული, მომავალი", "მომავალი, აწმყო, წარსული", "ნებისმიერი"], correct: 1 },
      { q: "რატომ უნდა მოამზადო კითხვები ინტერვიუერისთვის?", options: ["აუცილებელია", "აჩვენებ დაინტერესებას", "ფულის მისაღებად", "ვალდებულებაა"], correct: 1 },
      { q: "რამდენი ძლიერი მხარე უნდა ახსენო?", options: ["ერთი", "ორი-სამი", "ხუთი", "რაც შეიძლება ბევრი"], correct: 1 },
    ],
    descriptionKa: "გრძელი გაკვეთილი: მომზადდი სამსახურის გასაუბრებისთვის — 6 ყველაზე ხშირი კითხვა და იდეალური პასუხები.",
    transcript: [
      { speaker: "Teacher", en: "This lesson will teach you how to ace a job interview in English.", ka: "ეს გაკვეთილი გასწავლით როგორ წარმატებით გაიაროთ სამსახურის გასაუბრება ინგლისურად." },
      { speaker: "Teacher", en: "Question one: Tell me about yourself. Use the structure: Present, Past, Future.", ka: "კითხვა ერთი: მიამბეთ თქვენს შესახებ. გამოიყენეთ სტრუქტურა: აწმყო, წარსული, მომავალი." },
      { speaker: "Teacher", en: "Question three: What are your strengths? Pick two or three relevant strengths with examples.", ka: "კითხვა სამი: რა არის თქვენი ძლიერი მხარეები? აირჩიეთ ორი-სამი შესაბამისი მაგალითით." },
      { speaker: "Teacher", en: "Always prepare questions to ask the interviewer. It shows you are interested.", ka: "ყოველთვის მოამზადეთ კითხვები ინტერვიუერისთვის. ეს აჩვენებს რომ დაინტერესებული ხართ." }
    ]
  },
  { id: 35, title: "🎓 English for Traveling", titleKa: "ინგლისური მოგზაურობისთვის", icon: "🌍", duration: "10:00", file: "/podcast/episode35-travel-english.mp3", free: false,
    vocab: ["Check-in", "Boarding", "Immigration", "Customs", "Hotel reservation", "Taxi", "Sightseeing", "Emergency"],
    vocabKa: ["რეგისტრაცია", "ჩასხდომა", "იმიგრაცია", "საბაჟო", "სასტუმროს ჯავშანი", "ტაქსი", "ღირსშესანიშნაობები", "გადაუდებელი"],
    quiz: [
      { q: "იმიგრაციაზე რას გეკითხებიან?", options: ["სახელს", "ვიზიტის მიზანს", "პროფესიას", "ხელფასს"], correct: 1 },
      { q: "სასტუმროში ჯავშნის დროს რას ამბობ?", options: ["I want a room", "I have a reservation", "Give me a key", "Where is the room?"], correct: 1 },
      { q: "გადაუდებელ სიტუაციაში რას ამბობ?", options: ["Help me!", "I need a doctor", "Call the police", "ყველა სწორია"], correct: 3 },
    ],
    descriptionKa: "გრძელი გაკვეთილი: აეროპორტი, სასტუმრო, ტრანსპორტი, ტურიზმი და გადაუდებელი სიტუაციები — ყველაფერი რაც მოგზაურობისთვის გჭირდება.",
    transcript: [
      { speaker: "Teacher", en: "Planning a trip? This lesson covers everything you need to travel confidently in English.", ka: "მოგზაურობას გეგმავთ? ეს გაკვეთილი მოიცავს ყველაფერს რაც ინგლისურად მოგზაურობისთვის გჭირდებათ." },
      { speaker: "Teacher", en: "At the airport: May I see your passport and ticket? — Here you go.", ka: "აეროპორტში: შეიძლება პასპორტი და ბილეთი ვნახო? — ბრძანდით." },
      { speaker: "Teacher", en: "At immigration: What is the purpose of your visit? — I am here on vacation.", ka: "იმიგრაციაზე: რა არის ვიზიტის მიზანი? — შვებულებაში ვარ." },
      { speaker: "Teacher", en: "At the hotel: I have a reservation under the name Tornike.", ka: "სასტუმროში: ჯავშანი მაქვს, სახელზე — თორნიკე." },
      { speaker: "Teacher", en: "Emergency: I need a doctor. Where is the nearest hospital?", ka: "გადაუდებელი: ექიმი მჭირდება. სად არის უახლოესი საავადმყოფო?" }
    ]
  }
];
---

<Layout title="🎧 პოდკასტი — FluentGe">
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1478737270239-2f02b77fc618?w=1400&q=80" alt="" class="w-full h-full object-cover opacity-30"/>
      <div class="absolute inset-0 bg-gradient-to-b from-[#1C1C1E]/60 to-[#1C1C1E]"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 pt-24 pb-16 text-center">
      <h1 class="font-['Playfair_Display',serif] text-3xl sm:text-4xl md:text-5xl mb-4 leading-tight">პოდკასტი</h1>
      <p class="text-base sm:text-lg text-[#A0A09A] max-w-xl mx-auto">მოუსმინე და ისწავლე ინგლისური</p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-16">
    <div class="text-center mb-12">
      <p class="text-[#6B6B65] text-sm">{episodes.length} ეპიზოდი · 3 უფასო</p>
    </div>

    <div class="space-y-6">
      {episodes.map((ep) => (
        <div class={`bg-[#242426] border rounded-2xl overflow-hidden transition-all ${ep.free ? 'border-green-500/30' : 'border-[#2E2E30]'}`}>
          <div class="p-6">
            <div class="flex items-start justify-between mb-3">
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-sm text-[#6B6B65]">ეპიზოდი {ep.id}</span>
                  <span class="text-sm text-[#6B6B65]">· {ep.duration}</span>
                  {ep.free ? (
                    <span class="text-xs px-2 py-0.5 rounded-full bg-green-500/20 text-green-400 font-medium">✅ უფასო</span>
                  ) : (
                    <span class="text-xs px-2 py-0.5 rounded-full bg-amber-500/20 text-amber-400 font-medium">🔒 პრემიუმი</span>
                  )}
                </div>
                <h2 class="text-xl font-bold">{ep.title}</h2>
                <p class="text-[#6B6B65] text-sm">{ep.titleKa}</p>
              </div>
              <div class="text-4xl">{ep.icon}</div>
            </div>
            
            <p class="text-sm text-[#6B6B65] mb-4">{ep.descriptionKa}</p>

            <div class="mb-4">
              <p class="text-xs text-[#6B6B65] mb-2 font-medium">📚 სიტყვები ამ ეპიზოდში:</p>
              <div class="flex flex-wrap gap-2">
                {ep.vocab.map((word, i) => (
                  <span class="text-xs bg-[#242426] px-2 py-1 rounded-lg">
                    {word} <span class="text-[#6B6B65]">— {ep.vocabKa[i]}</span>
                  </span>
                ))}
              </div>
            </div>

            <div class={ep.free ? '' : 'podcast-premium-content hidden'}>
                <!-- Custom Audio Player -->
                <div class="podcast-player bg-[#1C1C1E] rounded-xl p-4 mb-4" data-ep={ep.id}>
                  <audio class="podcast-audio hidden" preload="metadata" data-ep-id={ep.id}>
                    <source src={ep.file} type="audio/mpeg" />
                  </audio>
                  <div class="flex items-center gap-3 mb-3">
                    <button class="pp-play w-12 h-12 rounded-full bg-sky-400 hover:bg-sky-500 border-b-4 border-sky-500 active:border-b-0 flex items-center justify-center text-white text-xl transition-all shrink-0" data-ep-id={ep.id}>▶</button>
                    <div class="flex-1">
                      <div class="pp-seek-wrap w-full h-2 bg-[#2E2E30] rounded-full cursor-pointer relative" data-ep-id={ep.id}>
                        <div class="pp-seek-fill h-full bg-gradient-to-r from-sky-400 to-emerald-400 rounded-full transition-all" style="width:0%"></div>
                      </div>
                      <div class="flex justify-between text-[10px] text-[#6B6B65] mt-1">
                        <span class="pp-time-current">0:00</span>
                        <span class="pp-time-total">{ep.duration}</span>
                      </div>
                    </div>
                  </div>
                  <!-- Speed controls -->
                  <div class="flex items-center gap-2 flex-wrap">
                    <span class="text-[10px] text-[#6B6B65] uppercase font-bold">სიჩქარე:</span>
                    {['0.5x', '0.75x', '1x', '1.25x', '1.5x'].map(spd => (
                      <button class={`pp-speed text-xs px-2.5 py-1 rounded-lg font-medium transition-all ${spd === '1x' ? 'bg-sky-400/20 text-sky-400 border border-sky-400/30' : 'bg-[#2E2E30] text-[#6B6B65] hover:text-[#C8C8C0]'}`} data-speed={parseFloat(spd)} data-ep-id={ep.id}>{spd}</button>
                    ))}
                    <div class="ml-auto flex items-center gap-2">
                      <button class="pp-lang-toggle text-xs px-2.5 py-1 rounded-lg bg-[#2E2E30] text-[#6B6B65] hover:text-emerald-400 transition-all" data-ep-id={ep.id} data-lang="both" title="ტექსტის ენა">🇬🇧+🇬🇪</button>
                      <button class="mark-podcast-btn inline-flex items-center gap-1 border border-[#6B6B65] rounded-lg px-3 py-1 text-xs text-[#6B6B65] hover:border-green-400 hover:text-green-400 transition-colors" data-podcast={ep.title}>✓ მოსმენილია</button>
                    </div>
                  </div>
                </div>

                <!-- Transcript (always visible) -->
                {ep.transcript && (
                  <div class="podcast-transcript bg-[#1C1C1E] rounded-xl p-4 space-y-2" data-ep-id={ep.id}>
                    <p class="text-xs text-[#6B6B65] font-bold uppercase tracking-wider mb-2">📝 დიალოგი</p>
                    {ep.transcript.map((line, lineIdx) => (
                      <div class={`transcript-line rounded-lg px-3 py-2 transition-all duration-300 border-l-2 ${line.speaker === ep.transcript[0].speaker ? 'border-purple-500/40' : 'border-emerald-500/40'}`} data-line={lineIdx}>
                        <div class="flex items-start gap-2">
                          <span class={`text-[10px] px-1.5 py-0.5 rounded font-bold shrink-0 mt-0.5 ${line.speaker === ep.transcript[0].speaker ? 'bg-purple-500/20 text-purple-400' : 'bg-emerald-500/20 text-emerald-400'}`}>
                            {line.speaker}
                          </span>
                          <div>
                            <p class="text-sm font-medium transcript-en">{line.en}</p>
                            <p class="text-xs text-[#6B6B65] mt-0.5 transcript-ka">{line.ka}</p>
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                )}

                <!-- Comprehension Quiz -->
                {ep.quiz && ep.quiz.length > 0 && (
                  <div class="podcast-quiz bg-[#1C1C1E] rounded-xl p-4 mt-4" data-ep-id={ep.id}>
                    <p class="text-xs text-[#6B6B65] font-bold uppercase tracking-wider mb-3">🧠 გაგების ტესტი</p>
                    <div class="space-y-4">
                      {ep.quiz.map((item, qi) => (
                        <div class="pq-question" data-ep={ep.id} data-qi={qi} data-correct={item.correct}>
                          <p class="text-sm font-semibold mb-2">{qi + 1}. {item.q}</p>
                          <div class="grid grid-cols-1 gap-2">
                            {item.options.map((opt, oi) => (
                              <button
                                class="pq-opt text-left w-full text-sm px-4 py-2.5 rounded-xl bg-[#242426] border border-white/10 border-b-4 border-b-white/5 hover:bg-[#2E2E30] active:border-b-2 active:mt-[2px] transition-all font-medium"
                                data-ep={ep.id}
                                data-qi={qi}
                                data-oi={oi}
                              >
                                <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-white/10 text-[10px] font-bold mr-2">{String.fromCharCode(65 + oi)}</span>
                                {opt}
                              </button>
                            ))}
                          </div>
                          <div class="pq-feedback hidden mt-2 text-sm font-medium px-3 py-2 rounded-lg"></div>
                        </div>
                      ))}
                      <div class="pq-result hidden text-center py-3" data-ep={ep.id}>
                        <div class="text-2xl mb-1">🎉</div>
                        <p class="font-bold text-green-400">ტესტი დასრულებულია!</p>
                        <p class="text-xs text-[#6B6B65] mt-1 pq-score"></p>
                      </div>
                    </div>
                  </div>
                )}
            </div>
            {!ep.free && (
              <a href="/premium/" class="podcast-lock-overlay block bg-gradient-to-r from-amber-500/10 to-orange-500/10 border border-amber-500/20 rounded-xl p-4 text-center hover:border-amber-500/40 transition-all">
                <span class="text-2xl">🔒</span>
                <p class="text-amber-400 font-medium mt-1">გახსენი პრემიუმით</p>
                <p class="text-xs text-[#6B6B65] mt-1">თვეში 9.99 ₾</p>
              </a>
            )}
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 bg-gradient-to-r from-amber-500/10 to-orange-500/10 border border-amber-500/20 rounded-2xl p-8 text-center">
      <h3 class="text-2xl font-bold mb-2">🔓 გახსენი ყველა ეპიზოდი</h3>
      <p class="text-[#6B6B65] mb-6">30 პოდკასტი, 3600+ სიტყვა, 38 გრამატიკის გაკვეთილი</p>
      <a href="/premium/" class="inline-block bg-[var(--color-primary)] hover:bg-[var(--color-primary-hover)] text-white font-bold py-3 px-8 rounded-xl text-lg transition-colors">
        🚀 დაიწყე პრემიუმი
      </a>
    </div>
  </section>

  <script is:inline>
    (function() {
      // Unlock premium podcasts
      if (localStorage.getItem('fluentge-premium') === 'true') {
        document.querySelectorAll('.podcast-premium-content').forEach(el => el.classList.remove('hidden'));
        document.querySelectorAll('.podcast-lock-overlay').forEach(el => el.remove());
        document.querySelectorAll('.text-amber-400').forEach(el => {
          if (el.textContent.trim() === '🔒 პრემიუმი') {
            el.textContent = '⭐ პრემიუმ';
            el.classList.remove('bg-amber-500/20', 'text-amber-400');
            el.classList.add('bg-green-500/20', 'text-green-400');
          }
        });
      }

      // Learned podcasts
      const learned = JSON.parse(localStorage.getItem('fluentge-learned-podcasts') || '[]');
      document.querySelectorAll('.mark-podcast-btn').forEach(btn => {
        const title = btn.dataset.podcast;
        if (learned.includes(title)) {
          btn.classList.remove('border-[#6B6B65]', 'text-[#6B6B65]');
          btn.classList.add('border-green-400', 'text-green-400', 'bg-green-400/10');
          btn.innerHTML = '✓ ✅';
        }
        btn.addEventListener('click', function() {
          const stored = JSON.parse(localStorage.getItem('fluentge-learned-podcasts') || '[]');
          if (stored.includes(title)) {
            stored.splice(stored.indexOf(title), 1);
            btn.classList.remove('border-green-400', 'text-green-400', 'bg-green-400/10');
            btn.classList.add('border-[#6B6B65]', 'text-[#6B6B65]');
            btn.innerHTML = '✓ მოსმენილია';
          } else {
            stored.push(title);
            btn.classList.add('border-green-400', 'text-green-400', 'bg-green-400/10');
            btn.classList.remove('border-[#6B6B65]', 'text-[#6B6B65]');
            btn.innerHTML = '✓ ✅';
          }
          localStorage.setItem('fluentge-learned-podcasts', JSON.stringify(stored));
        });
      });

      // Custom audio player logic
      function fmt(s) { const m = Math.floor(s/60); return m + ':' + String(Math.floor(s%60)).padStart(2,'0'); }

      document.querySelectorAll('.podcast-player').forEach(player => {
        const epId = player.dataset.ep;
        const audio = player.querySelector('.podcast-audio');
        const playBtn = player.querySelector('.pp-play');
        const seekWrap = player.querySelector('.pp-seek-wrap');
        const seekFill = player.querySelector('.pp-seek-fill');
        const timeCur = player.querySelector('.pp-time-current');
        const timeTotal = player.querySelector('.pp-time-total');

        // Play/pause
        playBtn.addEventListener('click', () => {
          // Pause all others
          document.querySelectorAll('.podcast-audio').forEach(a => { if (a !== audio && !a.paused) a.pause(); });
          document.querySelectorAll('.pp-play').forEach(b => { b.textContent = '▶'; });
          if (audio.paused) { audio.play(); playBtn.textContent = '⏸'; }
          else { audio.pause(); playBtn.textContent = '▶'; }
        });

        audio.addEventListener('loadedmetadata', () => { timeTotal.textContent = fmt(audio.duration); });
        audio.addEventListener('timeupdate', () => {
          if (!audio.duration) return;
          const pct = (audio.currentTime / audio.duration) * 100;
          seekFill.style.width = pct + '%';
          timeCur.textContent = fmt(audio.currentTime);

          // Highlight transcript line based on time
          const transcript = document.querySelector(`.podcast-transcript[data-ep-id="${epId}"]`);
          if (transcript) {
            const lines = transcript.querySelectorAll('.transcript-line');
            const totalLines = lines.length;
            if (totalLines > 0 && audio.duration) {
              const segLen = audio.duration / totalLines;
              const activeIdx = Math.min(Math.floor(audio.currentTime / segLen), totalLines - 1);
              lines.forEach((line, i) => {
                if (i === activeIdx) {
                  line.classList.add('bg-sky-500/10');
                  line.style.borderLeftColor = 'rgb(56, 189, 248)';
                } else {
                  line.classList.remove('bg-sky-500/10');
                  line.style.borderLeftColor = '';
                }
              });
            }
          }
        });
        audio.addEventListener('ended', () => { playBtn.textContent = '▶'; });

        // Seek
        seekWrap.addEventListener('click', (e) => {
          if (!audio.duration) return;
          const rect = seekWrap.getBoundingClientRect();
          audio.currentTime = ((e.clientX - rect.left) / rect.width) * audio.duration;
        });

        // Speed buttons
        player.querySelectorAll('.pp-speed').forEach(btn => {
          btn.addEventListener('click', () => {
            const speed = parseFloat(btn.dataset.speed);
            audio.playbackRate = speed;
            player.querySelectorAll('.pp-speed').forEach(b => {
              b.className = 'pp-speed text-xs px-2.5 py-1 rounded-lg font-medium transition-all bg-[#2E2E30] text-[#6B6B65] hover:text-[#C8C8C0]';
            });
            btn.className = 'pp-speed text-xs px-2.5 py-1 rounded-lg font-medium transition-all bg-sky-400/20 text-sky-400 border border-sky-400/30';
          });
        });
      });

      // Podcast quiz logic
      document.querySelectorAll('.pq-opt').forEach(btn => {
        btn.addEventListener('click', function() {
          const ep = this.dataset.ep;
          const qi = this.dataset.qi;
          const oi = parseInt(this.dataset.oi);
          const questionEl = document.querySelector(`.pq-question[data-ep="${ep}"][data-qi="${qi}"]`);
          if (!questionEl || questionEl.classList.contains('pq-answered')) return;
          questionEl.classList.add('pq-answered');
          const correct = parseInt(questionEl.dataset.correct);
          const feedback = questionEl.querySelector('.pq-feedback');
          
          // Highlight options
          questionEl.querySelectorAll('.pq-opt').forEach((opt, i) => {
            opt.style.pointerEvents = 'none';
            if (i === correct) {
              opt.classList.remove('bg-[#242426]', 'border-white/10', 'border-b-white/5');
              opt.classList.add('bg-green-500/20', 'border-green-500/30', 'text-green-400');
            } else if (i === oi && oi !== correct) {
              opt.classList.remove('bg-[#242426]', 'border-white/10', 'border-b-white/5');
              opt.classList.add('bg-red-500/20', 'border-red-500/30', 'text-red-400');
            }
          });
          
          feedback.classList.remove('hidden');
          if (oi === correct) {
            feedback.textContent = '✅ სწორია!';
            feedback.className = 'pq-feedback mt-2 text-sm font-medium px-3 py-2 rounded-lg bg-green-500/10 text-green-400';
            // Award XP
            if (window.FluentGe && window.FluentGe.addXP) window.FluentGe.addXP(10);
          } else {
            feedback.textContent = '❌ არასწორია';
            feedback.className = 'pq-feedback mt-2 text-sm font-medium px-3 py-2 rounded-lg bg-red-500/10 text-red-400';
          }
          
          // Check if all questions answered
          const allQs = document.querySelectorAll(`.pq-question[data-ep="${ep}"]`);
          const answeredQs = document.querySelectorAll(`.pq-question[data-ep="${ep}"].pq-answered`);
          if (allQs.length === answeredQs.length) {
            const correctCount = Array.from(answeredQs).filter(q => {
              const c = parseInt(q.dataset.correct);
              const chosen = q.querySelector('.pq-opt.bg-green-500\\/20, .pq-opt.bg-red-500\\/20');
              return chosen && parseInt(chosen.dataset.oi) === c;
            }).length;
            const resultEl = document.querySelector(`.pq-result[data-ep="${ep}"]`);
            if (resultEl) {
              resultEl.classList.remove('hidden');
              resultEl.querySelector('.pq-score').textContent = correctCount + '/' + allQs.length + ' სწორი პასუხი';
            }
          }
        });
      });

      // Language toggle for transcripts
      document.querySelectorAll('.pp-lang-toggle').forEach(btn => {
        btn.addEventListener('click', () => {
          const epId = btn.dataset.epId;
          const transcript = document.querySelector(`.podcast-transcript[data-ep-id="${epId}"]`);
          if (!transcript) return;
          const lang = btn.dataset.lang;
          const enEls = transcript.querySelectorAll('.transcript-en');
          const kaEls = transcript.querySelectorAll('.transcript-ka');
          if (lang === 'both') {
            kaEls.forEach(el => el.classList.add('hidden'));
            btn.dataset.lang = 'en';
            btn.textContent = '🇬🇧';
          } else if (lang === 'en') {
            enEls.forEach(el => el.classList.add('hidden'));
            kaEls.forEach(el => el.classList.remove('hidden'));
            btn.dataset.lang = 'ka';
            btn.textContent = '🇬🇪';
          } else {
            enEls.forEach(el => el.classList.remove('hidden'));
            kaEls.forEach(el => el.classList.remove('hidden'));
            btn.dataset.lang = 'both';
            btn.textContent = '🇬🇧+🇬🇪';
          }
        });
      });
    })();
  </script>
</Layout>
