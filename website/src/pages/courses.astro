---
import Layout from '../layouts/Layout.astro';

const units = [
  {
    id: 1, title: "საწყისი ნაბიჯები", titleEn: "First Steps", icon: "🌱", color: "from-green-400 to-emerald-500", border: "border-green-500/30",
    desc: "ძირითადი სიტყვები, გამოხატვები და A1 გრამატიკა",
    lessons: [
      { type: "vocab", icon: "📚", title: "გამარჯობა & მისალმებები", link: "/flashcards/", deck: "greetings" },
      { type: "grammar", icon: "📖", title: "To Be — ყოფნის ზმნა", link: "/grammar/to-be/" },
      { type: "podcast", icon: "🎧", title: "აეროპორტში", link: "/podcast/#ep-1" },
      { type: "vocab", icon: "📚", title: "რიცხვები & ფერები", link: "/flashcards/", deck: "numbers" },
      { type: "quiz", icon: "📝", title: "ერთეულის ტესტი", link: "/games/" },
    ]
  },
  {
    id: 2, title: "ყოველდღიური ცხოვრება", titleEn: "Daily Life", icon: "☀️", color: "from-sky-400 to-blue-500", border: "border-sky-500/30",
    desc: "საკვები, ემოციები, ოჯახი და A2 გრამატიკა",
    lessons: [
      { type: "vocab", icon: "📚", title: "საკვები & სასმელი", link: "/flashcards/", deck: "food" },
      { type: "grammar", icon: "📖", title: "Present Simple", link: "/grammar/present-simple/" },
      { type: "podcast", icon: "🎧", title: "რესტორანში", link: "/podcast/#ep-2" },
      { type: "vocab", icon: "📚", title: "ემოციები & გრძნობები", link: "/flashcards/", deck: "emotions" },
      { type: "quiz", icon: "📝", title: "ერთეულის ტესტი", link: "/games/" },
    ]
  },
  {
    id: 3, title: "მოგზაურობა", titleEn: "Travel & Places", icon: "✈️", color: "from-violet-400 to-purple-500", border: "border-violet-500/30",
    desc: "სასტუმრო, შოპინგი, მიმართულებები",
    lessons: [
      { type: "vocab", icon: "📚", title: "სასტუმრო & მოგზაურობა", link: "/flashcards/", deck: "travel" },
      { type: "grammar", icon: "📖", title: "Past Simple", link: "/grammar/past-simple/" },
      { type: "podcast", icon: "🎧", title: "სასტუმროში", link: "/podcast/#ep-4" },
      { type: "vocab", icon: "📚", title: "შოპინგი & ტანსაცმელი", link: "/flashcards/", deck: "shopping" },
      { type: "quiz", icon: "📝", title: "ერთეულის ტესტი", link: "/games/" },
    ]
  },
  {
    id: 4, title: "სამსახური & კარიერა", titleEn: "Work & Career", icon: "💼", color: "from-orange-400 to-amber-500", border: "border-orange-500/30",
    desc: "ოფისი, გასაუბრება, ბიზნეს ტერმინები",
    lessons: [
      { type: "vocab", icon: "📚", title: "ბიზნეს ინგლისური", link: "/flashcards/", deck: "business" },
      { type: "grammar", icon: "📖", title: "Present Perfect", link: "/grammar/present-perfect/" },
      { type: "podcast", icon: "🎧", title: "გასაუბრება სამსახურში", link: "/podcast/#ep-3" },
      { type: "vocab", icon: "📚", title: "ტექნოლოგია", link: "/flashcards/", deck: "technology" },
      { type: "quiz", icon: "📝", title: "ერთეულის ტესტი", link: "/games/" },
    ]
  },
  {
    id: 5, title: "ჯანმრთელობა & სპორტი", titleEn: "Health & Sports", icon: "💪", color: "from-rose-400 to-pink-500", border: "border-rose-500/30",
    desc: "სხეული, ექიმთან, სპორტდარბაზი",
    lessons: [
      { type: "vocab", icon: "📚", title: "სხეულის ნაწილები", link: "/flashcards/", deck: "body" },
      { type: "grammar", icon: "📖", title: "Modal Verbs", link: "/grammar/modal-verbs/" },
      { type: "podcast", icon: "🎧", title: "ექიმთან", link: "/podcast/#ep-6" },
      { type: "vocab", icon: "📚", title: "სპორტი & ფიტნესი", link: "/flashcards/", deck: "sports" },
      { type: "quiz", icon: "📝", title: "ერთეულის ტესტი", link: "/games/" },
    ]
  },
  {
    id: 6, title: "მოწინავე დონე", titleEn: "Advanced Topics", icon: "🏆", color: "from-yellow-400 to-orange-500", border: "border-yellow-500/30",
    desc: "აკადემიური, ბიზნეს და C1 გრამატიკა",
    lessons: [
      { type: "vocab", icon: "📚", title: "აკადემიური ლექსიკა", link: "/flashcards/", deck: "academic" },
      { type: "grammar", icon: "📖", title: "Conditionals", link: "/grammar/conditionals/" },
      { type: "podcast", icon: "🎧", title: "ბანკში", link: "/podcast/#ep-11" },
      { type: "vocab", icon: "📚", title: "იდიომები", link: "/flashcards/", deck: "idioms" },
      { type: "quiz", icon: "📝", title: "ფინალური ტესტი", link: "/games/" },
    ]
  },
];
---

<Layout title="კურსები — FluentGe">
  <section class="max-w-4xl mx-auto px-4 pt-24 pb-16">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="font-['Playfair_Display',serif] text-3xl sm:text-4xl font-bold mb-3">📚 სასწავლო კურსი</h1>
      <p class="text-[#A0A09A] text-lg max-w-xl mx-auto">სტრუქტურირებული გზა A1-დან C1-მდე — ლექსიკა, გრამატიკა, პოდკასტი და ტესტი ერთად</p>
      <div class="mt-4 flex items-center justify-center gap-4 text-sm">
        <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-green-400"></span> <span class="text-[#6B6B65]" id="cu-completed">0</span> გავლილი</span>
        <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-sky-400"></span> <span class="text-[#6B6B65]" id="cu-total">30</span> გაკვეთილი</span>
      </div>
    </div>

    <!-- Units -->
    <div class="space-y-6">
      {units.map((unit, uIdx) => (
        <div class={`unit-card bg-[#242426] border ${unit.border} rounded-2xl overflow-hidden transition-all`} data-unit={unit.id}>
          <!-- Unit header (clickable) -->
          <button class="unit-toggle w-full flex items-center gap-4 p-5 sm:p-6 text-left hover:bg-[#2E2E30]/50 transition-colors" data-target={`unit-${unit.id}`}>
            <!-- Icon circle -->
            <div class={`w-14 h-14 rounded-2xl bg-gradient-to-br ${unit.color} flex items-center justify-center text-2xl shrink-0 shadow-lg`}>
              {unit.icon}
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-0.5">
                <span class="text-xs font-bold text-[#6B6B65] uppercase">ერთეული {unit.id}</span>
                {uIdx > 1 && <span class="text-xs px-1.5 py-0.5 rounded bg-[#2E2E30] text-[#6B6B65]">🔒</span>}
              </div>
              <h2 class="font-bold text-lg truncate">{unit.title}</h2>
              <p class="text-sm text-[#6B6B65] truncate">{unit.desc}</p>
            </div>
            <!-- Progress circle -->
            <div class="shrink-0 text-right">
              <div class="text-2xl font-bold text-[#6B6B65]" data-unit-pct={unit.id}>0%</div>
              <div class="text-xs text-[#6B6B65]">{unit.lessons.length} გაკვეთილი</div>
            </div>
            <svg class="unit-chevron w-5 h-5 text-[#6B6B65] shrink-0 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>

          <!-- Lessons (collapsed by default, first unit open) -->
          <div id={`unit-${unit.id}`} class={`unit-lessons border-t border-[#2E2E30] ${uIdx === 0 ? '' : 'hidden'}`}>
            {unit.lessons.map((lesson, lIdx) => (
              <a href={lesson.link} class="flex items-center gap-3 px-5 sm:px-6 py-3.5 hover:bg-[#2E2E30]/50 transition-colors border-b border-[#2E2E30]/50 last:border-0 group" data-lesson={`${unit.id}-${lIdx}`}>
                <!-- Lesson number -->
                <div class="w-8 h-8 rounded-lg bg-[#2E2E30] flex items-center justify-center text-sm font-bold text-[#6B6B65] group-hover:bg-sky-500/20 group-hover:text-sky-400 transition-colors">
                  {lIdx + 1}
                </div>
                <!-- Type icon -->
                <span class="text-lg">{lesson.icon}</span>
                <!-- Title -->
                <span class="text-sm font-medium flex-1">{lesson.title}</span>
                <!-- Type badge -->
                <span class={`text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full ${
                  lesson.type === 'vocab' ? 'bg-sky-500/15 text-sky-400' :
                  lesson.type === 'grammar' ? 'bg-violet-500/15 text-violet-400' :
                  lesson.type === 'podcast' ? 'bg-emerald-500/15 text-emerald-400' :
                  'bg-orange-500/15 text-orange-400'
                }`}>{lesson.type === 'vocab' ? 'ლექსიკა' : lesson.type === 'grammar' ? 'გრამატიკა' : lesson.type === 'podcast' ? 'პოდკასტი' : 'ტესტი'}</span>
                <!-- Check/arrow -->
                <span class="lesson-check text-[#6B6B65] text-sm">→</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-12 text-center">
      <p class="text-[#6B6B65] text-sm mb-4">არ იცი საიდან დაიწყო?</p>
      <a href="/placement/" class="inline-block bg-sky-400 hover:bg-sky-500 text-white font-bold uppercase tracking-wide border-b-4 border-sky-500 active:border-b-0 rounded-xl px-8 py-3 transition-all">
        🎯 გაიარე დონის ტესტი
      </a>
    </div>
  </section>

  <script is:inline>
    (function() {
      // Toggle units
      document.querySelectorAll('.unit-toggle').forEach(btn => {
        btn.addEventListener('click', () => {
          const target = document.getElementById(btn.dataset.target);
          const chevron = btn.querySelector('.unit-chevron');
          if (target) {
            target.classList.toggle('hidden');
            chevron.style.transform = target.classList.contains('hidden') ? '' : 'rotate(180deg)';
          }
        });
      });

      // First unit chevron rotated
      const first = document.querySelector('.unit-toggle .unit-chevron');
      if (first) first.style.transform = 'rotate(180deg)';

      // Unlock logic: units 1-2 free, 3+ need premium
      const isPremium = localStorage.getItem('fluentge-premium') === 'true';
      if (isPremium) {
        document.querySelectorAll('[class*="🔒"]').forEach(el => el.remove());
      }
    })();
  </script>
</Layout>
