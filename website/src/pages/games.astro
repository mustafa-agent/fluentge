      if(b[id])b[id]();
    }

    // ============ GAME BUILDERS ============
    // Game records system
    function getGameRecords(){try{return JSON.parse(localStorage.getItem('fluentge-game-records')||'{}');}catch(e){return {};}}
    function saveGameRecord(gameId,score){
      const user=localStorage.getItem('fluentge-user');
      if(!user)return false;
      const records=getGameRecords();
      const prev=records[gameId]||0;
      if(score>prev){records[gameId]=score;localStorage.setItem('fluentge-game-records',JSON.stringify(records));return true;}
      return false;
    }
    function getGameRecord(gameId){return getGameRecords()[gameId]||0;}
    function saveLowRecord(gameId,score){
      const user=localStorage.getItem('fluentge-user');
      if(!user)return false;
      const records=getGameRecords();
      const prev=records[gameId];
      if(prev===undefined||score<prev){records[gameId]=score;localStorage.setItem('fluentge-game-records',JSON.stringify(records));return true;}
      return false;
    }
    function checkLowRecord(gameId,score){
      const isNew=saveLowRecord(gameId,score);
      const el=document.getElementById('game-record');
      if(el){el.textContent=score;if(isNew)el.closest('span').classList.add('!text-yellow-400','!border-yellow-400/40');}
      return isNew;
    }

    function gameWrap(title,desc,gameId){
      const rec=getGameRecord(gameId||'');
      const recHtml=gameId?`<div class="flex items-center gap-2 mb-4"><span class="text-xs bg-[#C8C8C0]/10 border border-[#C8C8C0]/20 rounded-full px-3 py-1 text-[#C8C8C0]">🏆 რეკორდი: <span id="game-record">${rec}</span></span></div>`:'';
      cont.innerHTML=`<div class="bg-[#242426] border border-[#2E2E30] rounded-2xl p-5 sm:p-8"><h2 class="text-xl sm:text-2xl font-bold mb-1 text-[#F5F5F0]">${title}</h2><p class="text-[#6B6B65] text-sm mb-4">${desc}</p>${recHtml}<div id="gc"></div></div>`;
      return document.getElementById('gc');
    }

    function checkRecord(gameId,score){
      const isNew=saveGameRecord(gameId,score);
      const el=document.getElementById('game-record');
      if(el&&isNew){el.textContent=score;el.closest('span').classList.add('!text-yellow-400','!border-yellow-400/40');}
      return isNew;
    }

    function buildMatch(){
      const gc=gameWrap('დაკავშირება','დააკავშირე ინგლისური სიტყვა ქართულ თარგმანთან','match');
      let score=0,timer=0,int,selE=null,selK=null,cnt=0;
      gc.innerHTML=`<div class="text-center mb-3 text-sm"><span class="text-[#C8C8C0] font-bold">ქულა: <span id="ms">0</span></span> <span class="text-[#6B6B65] ml-3">დრო: <span id="mt">0</span>წმ</span></div><div class="grid grid-cols-2 gap-3"><div id="ec" class="space-y-2"></div><div id="kc" class="space-y-2"></div></div><div id="mr" class="hidden mt-4 text-center"></div><button id="mn" class="mt-4 w-full bg-[#C8C8C0] hover:bg-[#B8B8B0] text-[#1C1C1E] font-semibold py-3 rounded-xl text-sm">ახალი რაუნდი</button>`;
      function start(){score=0;timer=0;cnt=0;selE=null;selK=null;document.getElementById('ms').textContent='0';document.getElementById('mt').textContent='0';document.getElementById('mr').classList.add('hidden');if(int)clearInterval(int);int=setInterval(()=>{timer++;document.getElementById('mt').textContent=timer;},1000);const r=sh(W).slice(0,6),es=sh(r),ks=sh(r);const ec=document.getElementById('ec'),kc=document.getElementById('kc');ec.innerHTML='';kc.innerHTML='';
      es.forEach(w=>{const b=h('button','w-full text-left px-3 py-2.5 rounded-lg border border-[#2E2E30] bg-[#242426] hover:bg-[#2E2E30] text-[#F5F5F0] transition-colors text-xs sm:text-sm font-medium',w.en);b.onclick=()=>{ec.querySelectorAll('button').forEach(x=>x.classList.remove('ring-2','ring-[#C8C8C0]'));b.classList.add('ring-2','ring-[#C8C8C0]');selE={b,w:w.en};chk();};ec.appendChild(b);});
      ks.forEach(w=>{const b=h('button','w-full text-left px-3 py-2.5 rounded-lg border border-[#2E2E30] bg-[#242426] hover:bg-[#2E2E30] text-[#F5F5F0] transition-colors text-xs sm:text-sm font-medium',w.ka);b.onclick=()=>{kc.querySelectorAll('button').forEach(x=>x.classList.remove('ring-2','ring-[#C8C8C0]'));b.classList.add('ring-2','ring-[#C8C8C0]');selK={b,w:w.en};chk();};kc.appendChild(b);});}
      function chk(){if(!selE||!selK)return;if(selE.w===selK.w){snd(1);score++;cnt++;document.getElementById('ms').textContent=score;selE.b.classList.add('bg-[#C8C8C0]/15','opacity-50','pointer-events-none');selK.b.classList.add('bg-[#C8C8C0]/15','opacity-50','pointer-events-none');if(cnt>=6){clearInterval(int);document.getElementById('mr').classList.remove('hidden');document.getElementById('mr').innerHTML=`<p class="text-xl font-bold text-[#C8C8C0]">${timer} წამში დაასრულე!</p>`;checkRecord('match',score);}}else{snd(0);const e=selE,k=selK;e.b.classList.add('bg-[#ef4444]/15');k.b.classList.add('bg-[#ef4444]/15');setTimeout(()=>{e.b.classList.remove('bg-[#ef4444]/15','ring-2','ring-[#C8C8C0]');k.b.classList.remove('bg-[#ef4444]/15','ring-2','ring-[#C8C8C0]');},500);}selE=null;selK=null;}
      document.getElementById('mn').onclick=start;start();
    }

    function buildSpeed(){
      const gc=gameWrap('სიჩქარის ქვიზი','30 წამი გაქვს — რამდენ სიტყვას დაიმახსოვრებ?','speed');
      gc.innerHTML=`<div id="ss" class="text-center"><button id="sg" class="bg-[#C8C8C0] hover:bg-[#B8B8B0] text-[#1C1C1E] font-bold py-4 px-10 rounded-xl text-base">დაიწყე</button></div><div id="sp" class="hidden"><div class="flex justify-between mb-4"><span class="text-[#C8C8C0] font-bold">ქულა: <span id="ssc">0</span></span><span class="text-[#ef4444] font-bold text-xl"><span id="st">30</span>წმ</span></div><p id="sw" class="text-2xl sm:text-3xl font-bold text-center mb-6"></p><div id="so" class="grid grid-cols-2 gap-3"></div></div><div id="sr" class="hidden text-center"><p class="text-2xl font-bold mb-2">შედეგი: <span id="sf" class="text-[#C8C8C0]"></span></p><p id="sm" class="text-[#6B6B65] mb-4"></p><button id="sy" class="bg-[#C8C8C0] hover:bg-[#B8B8B0] text-[#1C1C1E] font-bold py-3 px-8 rounded-xl text-sm">თავიდან</button></div>`;
      let sc=0,tl=30,si=null;
      function go(){sc=0;tl=30;document.getElementById('ssc').textContent='0';document.getElementById('st').textContent='30';document.getElementById('ss').classList.add('hidden');document.getElementById('sr').classList.add('hidden');document.getElementById('sp').classList.remove('hidden');if(si)clearInterval(si);si=setInterval(()=>{tl--;document.getElementById('st').textContent=tl;if(tl<=0){clearInterval(si);end();}},1000);nxt();}
      function nxt(){const c=rw(),wr=sh(W.filter(w=>w.en!==c.en)).slice(0,3),opts=sh([c,...wr]);document.getElementById('sw').textContent=c.en;const d=document.getElementById('so');d.innerHTML='';opts.forEach(o=>{const b=h('button','px-3 py-3 rounded-lg border border-[#2E2E30] bg-[#242426] hover:bg-[#2E2E30] text-[#F5F5F0] transition-colors font-medium text-xs sm:text-sm',o.ka);b.onclick=()=>{if(o.en===c.en){snd(1);sc++;document.getElementById('ssc').textContent=sc;}else snd(0);nxt();};d.appendChild(b);});}
      function end(){document.getElementById('sp').classList.add('hidden');document.getElementById('sr').classList.remove('hidden');document.getElementById('sf').textContent=sc+' სიტყვა';const isNew=checkRecord('speed',sc);document.getElementById('sm').textContent=isNew?'🏆 ახალი რეკორდი!':sc>=15?'ჩემპიონი!':sc>=10?'შესანიშნავი!':sc>=5?'კარგია!':'ივარჯიშე!';}
      document.getElementById('sg').onclick=go;document.getElementById('sy').onclick=go;
    }

    function buildTF(){
      const gc=gameWrap('სიმართლე / ტყუილი','ეს თარგმანი სწორია?','truefalse');
      gc.innerHTML=`<div class="text-center mb-6"><p id="te" class="text-2xl sm:text-3xl font-bold mb-2"></p><p class="text-[#6B6B65]">=</p><p id="tk" class="text-xl sm:text-2xl font-bold text-[#C8C8C0] mt-2"></p></div><div class="flex gap-3 justify-center mb-4"><button id="tt" class="flex-1 max-w-[180px] bg-green-500/10 hover:bg-[#C8C8C0]/15 border border-[#C8C8C0]/20 text-[#C8C8C0] font-bold py-3 rounded-xl text-sm">სიმართლე</button><button id="tf" class="flex-1 max-w-[180px] bg-red-500/10 hover:bg-[#ef4444]/15 border border-red-500/20 text-[#ef4444] font-bold py-3 rounded-xl text-sm">ტყუილი</button></div><div id="tb" class="text-center font-bold mb-2"></div><div class="text-center text-sm"><span class="text-[#C8C8C0] font-bold"><span id="ts">0</span>/<span id="to">0</span></span></div>`;
      let sc=0,tot=0,correct,word;
      function nxt(){word=rw();const isT=Math.random()>0.4;if(isT){document.getElementById('tk').textContent=word.ka;correct=true;}else{const wr=W.filter(w=>w.en!==word.en);document.getElementById('tk').textContent=wr[Math.floor(Math.random()*wr.length)].ka;correct=false;}document.getElementById('te').textContent=word.en;document.getElementById('tb').innerHTML='';}
      function ans(p){tot++;document.getElementById('to').textContent=tot;if(p===correct){snd(1);sc++;document.getElementById('ts').textContent=sc;checkRecord('truefalse',sc);document.getElementById('tb').innerHTML='<p class="text-[#C8C8C0] text-sm">სწორია!</p>';}else{snd(0);document.getElementById('tb').innerHTML=`<p class="text-[#ef4444] text-sm">${word.en} = ${word.ka}</p>`;}setTimeout(nxt,1200);}
      document.getElementById('tt').onclick=()=>ans(true);document.getElementById('tf').onclick=()=>ans(false);nxt();
    }

    // Generic quiz builder for list-based games
    function buildListQuiz(title,desc,data,getQ,getA,getOpts,gameId){
      const gc=gameWrap(title,desc,gameId);let sc=0;
      gc.innerHTML=`<p id="lqw" class="text-xl sm:text-2xl font-bold text-center mb-6"></p><div id="lqo" class="grid grid-cols-2 gap-3 mb-4"></div><div id="lqf" class="text-center font-bold mb-2"></div><div class="text-center text-sm"><span class="text-[#C8C8C0] font-bold">ქულა: <span id="lqs">0</span></span></div>`;
      function nw(){const q=data[Math.floor(Math.random()*data.length)];document.getElementById('lqw').textContent=getQ(q);document.getElementById('lqf').innerHTML='';const ans=getA(q);const opts=sh([ans,...sh(getOpts(data,q)).slice(0,3)]);const d=document.getElementById('lqo');d.innerHTML='';opts.forEach(o=>{const b=h('button','px-3 py-3 rounded-lg border border-[#2E2E30] bg-[#242426] hover:bg-[#2E2E30] text-[#F5F5F0] transition-colors font-medium text-xs sm:text-sm',o);b.onclick=()=>{if(o===ans){snd(1);sc++;document.getElementById('lqs').textContent=sc;if(gameId)checkRecord(gameId,sc);setTimeout(nw,500);}else{snd(0);b.classList.add('opacity-30','pointer-events-none');}};d.appendChild(b);});}
      nw();
