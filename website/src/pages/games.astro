    const emojiQ=[{e:"https://images.unsplash.com/photo-1504386106331-3e4e71712b38?w=200&q=60",a:"Hot",ka:"ცხელი",o:["Hot","Cold","Rain","Snow"]},{e:"https://images.unsplash.com/photo-1503676260728-1c00da094a0b?w=200&q=60",a:"School",ka:"სკოლა",o:["School","Work","Home","Shop"]},{e:"https://images.unsplash.com/photo-1511379938547-c1f69419868d?w=200&q=60",a:"Music",ka:"მუსიკა",o:["Music","Dance","Movie","Game"]},{e:"https://images.unsplash.com/photo-1511895426328-dc8714191300?w=200&q=60",a:"Family",ka:"ოჯახი",o:["Family","Friend","Teacher","Doctor"]},{e:"https://images.unsplash.com/photo-1532978379173-523e16f371f2?w=200&q=60",a:"Night",ka:"ღამე",o:["Night","Day","Morning","Evening"]},{e:"https://images.unsplash.com/photo-1518199266791-5375a83190b7?w=200&q=60",a:"Love",ka:"სიყვარული",o:["Love","Happy","Sad","Strong"]},{e:"https://images.unsplash.com/photo-1494976388531-d1058494cdd8?w=200&q=60",a:"Fast",ka:"სწრაფი",o:["Fast","Slow","Big","Small"]},{e:"https://images.unsplash.com/photo-1509440159596-0249088772ff?w=200&q=60",a:"Bread",ka:"პური",o:["Bread","Cheese","Milk","Water"]},{e:"https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=200&q=60",a:"Mountain",ka:"მთა",o:["Mountain","River","Sea","Garden"]},{e:"https://images.unsplash.com/photo-1436491865332-7a61a109db05?w=200&q=60",a:"Airport",ka:"აეროპორტი",o:["Airport","Hospital","School","Bridge"]}];
    const sentences=[{t:"I ___ a student.",a:"am",h:"be ზმნა (მე)"},{t:"She ___ to school every day.",a:"goes",h:"go — მესამე პირი"},{t:"They ___ playing football.",a:"are",h:"be (ისინი)"},{t:"He ___ a big house.",a:"has",h:"have — მესამე პირი"},{t:"We ___ English yesterday.",a:"studied",h:"study — წარსული"},{t:"The cat is ___ the table.",a:"on",h:"წინდებული"},{t:"I ___ like coffee.",a:"don't",h:"უარყოფა"},{t:"She ___ reading a book now.",a:"is",h:"be (ის)"},{t:"Can you ___ me?",a:"help",h:"დახმარება"},{t:"It ___ raining outside.",a:"is",h:"be ზმნა"},{t:"I want ___ go home.",a:"to",h:"ნაწილაკი"},{t:"There ___ many people here.",a:"are",h:"be — მრავლობითი"}];
