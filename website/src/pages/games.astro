---
import Layout from '../layouts/Layout.astro';
---

<Layout title="თამაშები — FluentGe">
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1553481187-be93c21490a9?w=1400&q=80" alt="" class="w-full h-full object-cover opacity-25"/>
      <div class="absolute inset-0 bg-gradient-to-b from-[#1C1C1E]/60 to-[#1C1C1E]"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 pt-24 pb-16 text-center">
      <h1 class="font-['Playfair_Display',serif] text-3xl sm:text-4xl md:text-5xl mb-4 leading-tight">სიტყვების თამაშები</h1>
      <p class="text-base sm:text-lg text-[#A0A09A] max-w-xl mx-auto mb-6">ისწავლე ინგლისური სახალისო და ინტერაქტიული თამაშებით</p>
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/10 rounded-full px-5 py-2">
        <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
        <span class="text-sm text-[#C8C8C0]">3 უფასო თამაში</span>
        <span class="text-[#6B6B65]">|</span>
        <span class="text-sm text-[#C8C8C0]">27 პრემიუმ</span>
      </div>
    </div>
  </section>

  <!-- Games Stats Bar -->
  <section class="max-w-5xl mx-auto px-4 pt-8">
    <div id="games-stats" class="flex items-center justify-center gap-4 sm:gap-6 bg-[#242426] border border-[#2E2E30] rounded-2xl px-4 py-3">
      <div class="flex items-center gap-1.5">
        <span class="text-yellow-400 text-lg">⭐</span>
        <span class="text-sm font-bold text-[#F5F5F0]" id="gs-xp">0</span>
        <span class="text-xs text-[#6B6B65]">XP</span>
      </div>
      <div class="flex items-center gap-1.5">
        <span class="text-purple-400 text-lg">🏆</span>
        <span class="text-sm font-bold text-[#F5F5F0]">Lv.<span id="gs-level">1</span></span>
      </div>
      <div class="w-20 sm:w-28 h-2.5 bg-white/10 rounded-full overflow-hidden">
        <div id="gs-bar" class="h-full bg-gradient-to-r from-yellow-400 to-amber-500 rounded-full transition-all duration-500" style="width:0%"></div>
      </div>
      <div class="flex items-center gap-1.5">
        <span class="text-green-400 text-lg">🎮</span>
        <span class="text-sm font-bold text-[#F5F5F0]" id="gs-played">0</span>
      </div>
      <div class="flex items-center gap-1.5">
        <span class="text-orange-400 text-lg">🔥</span>
        <span class="text-sm font-bold text-[#F5F5F0]" id="gs-streak">0</span>
      </div>
    </div>
  </section>

  <!-- Game of the Day Spotlight -->
  <section class="max-w-5xl mx-auto px-4 pt-8">
    <div id="game-of-day" class="relative overflow-hidden bg-gradient-to-r from-indigo-600/20 via-purple-600/20 to-pink-600/20 border border-indigo-500/20 rounded-2xl p-6 sm:p-8 cursor-pointer hover:border-indigo-400/40 transition-all group">
      <div class="absolute top-3 right-3 text-[10px] font-bold uppercase tracking-widest bg-indigo-500/30 text-indigo-300 px-3 py-1 rounded-full">⭐ დღის თამაში</div>
      <div class="flex items-center gap-5">
        <div id="god-icon" class="w-16 h-16 rounded-2xl bg-indigo-500/20 flex items-center justify-center text-3xl shrink-0 border-b-4 border-indigo-500/30"></div>
        <div class="flex-1">
          <h3 id="god-name" class="text-xl font-bold mb-1"></h3>
          <p id="god-desc" class="text-[#A0A09A] text-sm"></p>
        </div>
        <div class="text-2xl group-hover:translate-x-1 transition-transform text-indigo-300">▶</div>
      </div>
    </div>
  </section>

  <!-- Game Grid -->
  <section class="max-w-5xl mx-auto px-4 py-8">
    <!-- Free Games Section -->
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-6">
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-green-500/20 to-transparent"></div>
        <h2 class="text-sm font-bold uppercase tracking-widest text-green-400">🆓 უფასო თამაშები</h2>
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-green-500/20 to-transparent"></div>
      </div>
      <div id="free-games" class="grid grid-cols-1 sm:grid-cols-3 gap-4"></div>
    </div>

    <!-- Category: Vocabulary Games -->
    <div class="mb-10" id="cat-vocab">
      <div class="flex items-center gap-3 mb-6">
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-sky-500/20 to-transparent"></div>
        <h2 class="text-sm font-bold uppercase tracking-widest text-sky-400">📚 ლექსიკის თამაშები</h2>
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-sky-500/20 to-transparent"></div>
      </div>
      <div id="vocab-games" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 sm:gap-4"></div>
    </div>

    <!-- Category: Grammar & Skills -->
    <div class="mb-10" id="cat-grammar">
      <div class="flex items-center gap-3 mb-6">
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-violet-500/20 to-transparent"></div>
        <h2 class="text-sm font-bold uppercase tracking-widest text-violet-400">📝 გრამატიკა & უნარები</h2>
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-violet-500/20 to-transparent"></div>
      </div>
      <div id="grammar-games" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 sm:gap-4"></div>
    </div>

    <!-- Category: Fun & Challenge -->
    <div class="mb-10" id="cat-fun">
      <div class="flex items-center gap-3 mb-6">
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-amber-500/20 to-transparent"></div>
        <h2 class="text-sm font-bold uppercase tracking-widest text-amber-400">🎯 გართობა & გამოწვევა</h2>
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-amber-500/20 to-transparent"></div>
      </div>
      <div id="fun-games" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 sm:gap-4"></div>
    </div>

    <!-- Legacy containers (hidden, used by JS fallback) -->
    <div id="premium-section" style="display:none">
      <div id="premium-games"></div>
    </div>
  </section>

  <!-- Active Game Area -->
  <div id="game-overlay" class="hidden fixed inset-0 z-40 bg-[#1C1C1E] overflow-y-auto">
    <div class="max-w-xl mx-auto px-4 pt-16 pb-6 min-h-screen">
      <button id="back-btn" class="flex items-center gap-2 text-[#6B6B65] hover:text-[#F5F5F0] transition-colors text-sm mb-6">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"></path><path d="M12 19l-7-7 7-7"></path></svg>
        უკან
      </button>
      <div id="game-container"></div>
    </div>
  </div>

  <!-- Subscribe Modal -->
  <div id="sub-modal" class="hidden fixed inset-0 bg-black/40 backdrop-blur-sm z-50 flex items-center justify-center p-4">
    <div class="bg-[#242426] border border-[#2E2E30] rounded-2xl p-6 sm:p-8 max-w-sm w-full text-center shadow-lg">
      <div class="w-16 h-16 bg-[#C8C8C0]/10 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#C8C8C0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
      </div>
      <h2 class="text-xl sm:text-2xl font-bold mb-2 text-[#F5F5F0]">პრემიუმ თამაში</h2>
      <p class="text-[#6B6B65] text-sm mb-6">განბლოკე ყველა 27 თამაში პრემიუმ გამოწერით</p>
      <button id="sub-btn" class="w-full bg-[#C8C8C0] hover:bg-[#B8B8B0] text-[#1C1C1E] font-bold py-3 rounded-xl text-base transition-colors mb-3">გამოიწერე პრემიუმი</button>
      <button id="sub-close" class="w-full bg-[#242426] hover:bg-[#2E2E30] text-[#A0A09A] py-2 rounded-xl transition-colors text-sm">დახურვა</button>
    </div>
  </div>

  <style>
    .game-card {
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      border-bottom-width: 4px;
      border-bottom-color: rgba(0,0,0,0.3);
    }
    .game-card:hover {
      transform: translateY(-3px);
    }
    .game-card:active {
      border-bottom-width: 2px;
      transform: translateY(0px);
    }
    .game-card:hover img { opacity: 0.9 !important; transform: scale(1.05); }
    .game-card img { transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1); }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .game-card { animation: fadeIn 0.4s ease-out backwards; }
    @keyframes xpFloatUp {
      0% { opacity: 1; transform: translateY(0); }
      100% { opacity: 0; transform: translateY(-60px); }
    }
    .xp-float-anim {
      color: #facc15; font-weight: 800; font-size: 18px; z-index: 9999;
      pointer-events: none; animation: xpFloatUp 1.2s ease-out forwards;
      text-shadow: 0 1px 4px rgba(0,0,0,0.5);
    }
    .level-up-popup {
      position: fixed; inset: 0; z-index: 9999; display: flex; align-items: center; justify-content: center;
      background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);
      animation: fadeIn 0.3s ease-out;
    }
    .level-up-inner {
      background: linear-gradient(135deg, #7c3aed, #a855f7); padding: 2rem 3rem;
      border-radius: 1.5rem; text-align: center; color: white;
      animation: levelPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    @keyframes levelPop {
      0% { transform: scale(0.5); opacity: 0; }
      100% { transform: scale(1); opacity: 1; }
    }
  </style>

