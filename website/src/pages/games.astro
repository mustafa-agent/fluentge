    function sh(a){const r=[...a];for(let i=r.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[r[i],r[j]]=[r[j],r[i]];}return r;}
    function rw(){return W[Math.floor(Math.random()*W.length)];}
    let actx=null;
    function snd(ok){try{if(!actx)actx=new(window.AudioContext||window.webkitAudioContext)();if(actx.state==='suspended')actx.resume();const o=actx.createOscillator(),g=actx.createGain();o.connect(g);g.connect(actx.destination);g.gain.setValueAtTime(0.13,actx.currentTime);o.type='sine';if(ok){o.frequency.setValueAtTime(523,actx.currentTime);o.frequency.setValueAtTime(659,actx.currentTime+0.1);}else{o.frequency.setValueAtTime(330,actx.currentTime);o.frequency.setValueAtTime(262,actx.currentTime+0.15);}g.gain.exponentialRampToValueAtTime(0.001,actx.currentTime+0.3);o.start(actx.currentTime);o.stop(actx.currentTime+0.35);}catch(e){}}
    function h(tag,cls='',html=''){const e=document.createElement(tag);e.className=cls;e.innerHTML=html;return e;}

    // ============ GAMES XP SYSTEM ============
    const GAME_XP = { CORRECT: 10, STREAK_BONUS: 5, COMPLETION: 50 };
    function getGamesTotalXP(){ return parseInt(localStorage.getItem('totalXP')||'0',10); }
    function getGamesLevel(xp){ return Math.floor(xp/200)+1; }
    function addGameXP(amount){
      const cur=getGamesTotalXP(); const curLv=getGamesLevel(cur);
      const nw=cur+amount; const nwLv=getGamesLevel(nw);
      localStorage.setItem('totalXP',nw.toString());
      // Update streak
      const today=new Date().toDateString();
      const lastDate=localStorage.getItem('lastPracticeDate');
      if(lastDate!==today){
        const yesterday=new Date(Date.now()-86400000).toDateString();
        const streak=parseInt(localStorage.getItem('currentStreak')||'0',10);
        if(lastDate===yesterday||!lastDate){localStorage.setItem('currentStreak',(streak+1).toString());}
        else{localStorage.setItem('currentStreak','1');}
        localStorage.setItem('lastPracticeDate',today);
      }
      // Track study time
      try{const st=JSON.parse(localStorage.getItem('dailyStudyTime')||'{}');
        if(st.date===today){st.minutes=(st.minutes||0)+0.5;}else{st.date=today;st.minutes=0.5;}
        localStorage.setItem('dailyStudyTime',JSON.stringify(st));
      }catch(e){}
      // Track games played
      const gp=parseInt(localStorage.getItem('gamesPlayed')||'0',10);
      localStorage.setItem('gamesPlayed',(gp+1).toString());
      // Track today's games
      try{const tg=JSON.parse(localStorage.getItem('todayGames')||'{}');
        if(tg.date===today){tg.count=(tg.count||0)+1;tg.xp=(tg.xp||0)+amount;}
        else{tg.date=today;tg.count=1;tg.xp=amount;}
        localStorage.setItem('todayGames',JSON.stringify(tg));
      }catch(e){}
      return {newTotal:nw,levelUp:nwLv>curLv,newLevel:nwLv};
    }
    // Floating +XP animation
    function showXPFloat(el,amount){
      const f=document.createElement('div');
      f.className='xp-float-anim';
      f.textContent='+'+amount+' XP';
      if(el){const r=el.getBoundingClientRect();const p=el.closest('#game-container')||el.parentElement;
        f.style.position='fixed';f.style.left=(r.left+r.width/2-30)+'px';f.style.top=(r.top-10)+'px';
      }else{f.style.position='fixed';f.style.top='40%';f.style.left='50%';f.style.transform='translateX(-50%)';}
      document.body.appendChild(f);
      setTimeout(()=>f.remove(),1200);
    }
    // Level-up popup
    function showLevelUp(level){
      const d=document.createElement('div');
      d.className='level-up-popup';
      d.innerHTML=`<div class="level-up-inner"><span class="text-4xl">🎉</span><p class="text-xl font-bold mt-2">Level ${level}!</p><p class="text-sm text-[#A0A09A]">ახალ დონეზე გადახვედი!</p></div>`;
      document.body.appendChild(d);
      setTimeout(()=>d.remove(),2500);
    }
    // XP header for game overlay
    function updateGameXPHeader(){
      let hdr=document.getElementById('game-xp-header');
      if(!hdr){
        hdr=document.createElement('div');hdr.id='game-xp-header';
        hdr.className='flex items-center justify-center gap-4 mb-4 text-sm';
        const gc=document.getElementById('game-container');
        if(gc)gc.parentElement.insertBefore(hdr,gc);
      }
      const xp=getGamesTotalXP();const lv=getGamesLevel(xp);
      const xpInLevel=xp-((lv-1)*200);const pct=Math.min(100,(xpInLevel/200)*100);
