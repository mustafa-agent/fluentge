      gc.innerHTML=`<div id="rtl" class="space-y-2 mb-4"></div><button id="rtc" class="w-full bg-[#C8C8C0] hover:bg-[#B8B8B0] text-[#1C1C1E] font-semibold py-2.5 rounded-xl text-sm mb-2">შემოწმება</button><div id="rtf" class="text-center font-bold mb-2"></div><button id="rtn" class="w-full bg-[#2E2E30] hover:bg-[#3E3E40] text-[#A0A09A] py-2 rounded-xl text-xs">ახალი</button><div class="text-center mt-2 text-sm"><span class="text-[#C8C8C0] font-bold">ქულა: <span id="rts">0</span></span></div>`;
      function nw(){const items=sh(dailyRoutine.slice(0,8));const d=document.getElementById('rtl');d.innerHTML='';document.getElementById('rtf').innerHTML='';items.forEach((item,i)=>{const row=h('div','flex items-center gap-3 bg-[#242426] border border-[#2E2E30] rounded-lg px-3 py-2.5 cursor-grab text-xs sm:text-sm',`<span class="text-[#6B6B65] font-bold w-5">${i+1}.</span><span class="flex-1"><strong>${item.en}</strong> <span class="text-[#C8C8C0]">(${item.ka})</span></span>`);row.dataset.order=item.order;row.draggable=true;row.ondragstart=e=>e.dataTransfer.setData('text',String(i));row.ondragover=e=>e.preventDefault();row.ondrop=e=>{e.preventDefault();const from=parseInt(e.dataTransfer.getData('text'));const rows=[...d.children];const el=rows[from];d.removeChild(el);d.insertBefore(el,row);[...d.children].forEach((r,j)=>r.querySelector('span').textContent=(j+1)+'.');};d.appendChild(row);});}
      document.getElementById('rtc').onclick=()=>{const rows=[...document.getElementById('rtl').children];const orders=rows.map(r=>parseInt(r.dataset.order));let ok=true;for(let i=1;i<orders.length;i++){if(orders[i]<orders[i-1]){ok=false;break;}}if(ok){snd(1);sc++;document.getElementById('rts').textContent=sc;checkRecord('routine',sc);document.getElementById('rtf').innerHTML='<p class="text-[#C8C8C0] text-sm">სწორია!</p>';}else{snd(0);document.getElementById('rtf').innerHTML='<p class="text-[#ef4444] text-sm">თანმიმდევრობა არასწორია!</p>';}};
      document.getElementById('rtn').onclick=nw;nw();
    }

    function buildSpelling(){
      const gc=gameWrap('მართლწერა','მოუსმინე და სწორად დაწერე','spelling');let w,sc=0;
      gc.innerHTML=`<div class="text-center mb-5"><button id="spk" class="bg-[#C8C8C0] hover:bg-[#B8B8B0] text-[#1C1C1E] font-bold py-4 px-10 rounded-xl text-base">მოსმენა</button></div><p id="sph" class="text-[#C8C8C0] text-center text-sm mb-4"></p><div class="max-w-xs mx-auto mb-3"><input id="spi" type="text" placeholder="ჩაწერე..." class="w-full px-4 py-3 rounded-xl bg-[#242426] border border-white/20 text-[#F5F5F0] text-center text-base focus:outline-none focus:border-[#C8C8C0]" autocomplete="off"/></div><div class="flex gap-2 justify-center mb-3"><button id="spc" class="bg-[#C8C8C0] hover:bg-[#B8B8B0] text-[#1C1C1E] px-5 py-2 rounded-lg font-semibold text-sm">შემოწმება</button><button id="sps" class="bg-[#242426] hover:bg-[#2E2E30] text-white px-5 py-2 rounded-lg font-semibold text-sm">გამოტოვება</button></div><div id="spf" class="text-center font-bold mb-2"></div><div class="text-center text-sm"><span class="text-[#C8C8C0] font-bold">ქულა: <span id="spsc">0</span></span></div>`;
      function nw(){w=rw();document.getElementById('sph').textContent=w.ka;document.getElementById('spi').value='';document.getElementById('spf').innerHTML='';}
      document.getElementById('spk').onclick=()=>{const u=new SpeechSynthesisUtterance(w.en);u.lang='en-US';u.rate=0.7;speechSynthesis.speak(u);};
      document.getElementById('spc').onclick=()=>{if(document.getElementById('spi').value.trim().toLowerCase()===w.en.toLowerCase()){snd(1);sc++;document.getElementById('spsc').textContent=sc;checkRecord('spelling',sc);document.getElementById('spf').innerHTML='<p class="text-[#C8C8C0] text-sm">სწორია!</p>';setTimeout(nw,800);}else{snd(0);document.getElementById('spf').innerHTML=`<p class="text-[#ef4444] text-sm">${w.en}</p>`;}};
      document.getElementById('sps').onclick=()=>{document.getElementById('spf').innerHTML=`<p class="text-[#eab308] text-sm">${w.en}</p>`;setTimeout(nw,1500);};
      document.getElementById('spi').onkeydown=e=>{if(e.key==='Enter')document.getElementById('spc').click();};
      nw();
    }

    function buildWordRace(){
      const gc=gameWrap('სიტყვის რბოლა','ყოველ დონეზე დრო მცირდება','wordrace');let sc=0,tl=5,si=null,w;
      gc.innerHTML=`<div class="flex justify-between mb-3 text-sm"><span class="text-[#C8C8C0] font-bold">დონე: <span id="wrl">1</span></span><span class="text-[#ef4444] font-bold text-lg"><span id="wrt">5</span>წმ</span></div><p id="wrw" class="text-2xl font-bold text-center mb-1"></p><p id="wrk" class="text-[#C8C8C0] text-xs text-center mb-4"></p><div class="max-w-xs mx-auto mb-3"><input id="wri" type="text" placeholder="აკრიფე..." class="w-full px-4 py-3 rounded-xl bg-[#242426] border border-white/20 text-[#F5F5F0] text-center text-base focus:outline-none focus:border-[#C8C8C0]" autocomplete="off"/></div><div id="wrf" class="text-center font-bold mb-2"></div><div class="text-center text-sm"><span class="text-[#C8C8C0] font-bold">ქულა: <span id="wrs">0</span></span></div>`;
      function nw(){w=rw();tl=Math.max(2,6-Math.floor(sc/3));document.getElementById('wrl').textContent=Math.floor(sc/3)+1;document.getElementById('wrt').textContent=tl;document.getElementById('wrw').textContent=w.en;document.getElementById('wrk').textContent=w.ka;document.getElementById('wri').value='';document.getElementById('wrf').innerHTML='';document.getElementById('wri').focus();if(si)clearInterval(si);si=setInterval(()=>{tl--;document.getElementById('wrt').textContent=tl;if(tl<=0){clearInterval(si);snd(0);document.getElementById('wrf').innerHTML=`<p class="text-[#ef4444] text-sm">დრო! ${w.en}</p>`;sc=0;document.getElementById('wrs').textContent=0;setTimeout(nw,2000);}},1000);
      document.getElementById('wri').oninput=e=>{if(e.target.value.trim().toLowerCase()===w.en.toLowerCase()){clearInterval(si);snd(1);sc++;document.getElementById('wrs').textContent=sc;checkRecord('wordrace',sc);document.getElementById('wrf').innerHTML='<p class="text-[#C8C8C0] text-sm">სწორია!</p>';setTimeout(nw,500);}};}
      nw();
    }

    function buildColors(){
      const gc=gameWrap('ფერები','რა ფერია ეს?','colorsquiz');let sc=0;
      gc.innerHTML=`<div id="clr" class="w-24 h-24 sm:w-32 sm:h-32 rounded-2xl mx-auto mb-5"></div><div id="clo" class="grid grid-cols-2 gap-3 mb-3"></div><div id="clf" class="text-center font-bold mb-2"></div><div class="text-center text-sm"><span class="text-[#C8C8C0] font-bold">ქულა: <span id="cls">0</span></span></div>`;
      function nw(){const q=colors[Math.floor(Math.random()*colors.length)];document.getElementById('clr').style.background=q.hex;document.getElementById('clf').innerHTML='';const opts=sh([q,...sh(colors.filter(c=>c.en!==q.en)).slice(0,3)]);const d=document.getElementById('clo');d.innerHTML='';opts.forEach(o=>{const b=h('button','px-3 py-3 rounded-lg border border-[#2E2E30] bg-[#242426] hover:bg-[#2E2E30] text-[#F5F5F0] transition-colors font-medium text-xs sm:text-sm',o.en+' ('+o.ka+')');b.onclick=()=>{if(o.en===q.en){snd(1);sc++;document.getElementById('cls').textContent=sc;checkRecord('colorsquiz',sc);setTimeout(nw,500);}else{snd(0);b.classList.add('opacity-30','pointer-events-none');}};d.appendChild(b);});}
      nw();
    }

    function buildTime(){buildListQuiz('რომელი საათია','ისწავლე დროის თქმა',times,q=>q.d,q=>q.en,(d,q)=>d.filter(t=>t.en!==q.en).map(t=>t.en),'timequiz');}

    function buildCat(){
      const cats=[{name:"Animals",ka:"ცხოველები",words:["Cat","Dog","Bird","Fish","Horse"],wrong:["Table","Book","Car"]},{name:"Food",ka:"საკვები",words:["Bread","Cheese","Milk","Apple","Egg"],wrong:["Chair","Phone","Star"]},{name:"Body",ka:"სხეული",words:["Hand","Head","Eye","Heart"],wrong:["Tree","Rain","Money"]},{name:"Family",ka:"ოჯახი",words:["Mother","Father","Brother","Sister","Son"],wrong:["River","Mountain","School"]},{name:"Colors",ka:"ფერები",words:["Red","Blue","Green","Yellow","White"],wrong:["Fast","Big","Happy"]}];
      const gc=gameWrap('კატეგორიები','აირჩიე სწორი სიტყვები','categories');let sc=0;
      gc.innerHTML=`<p id="catw" class="text-xl font-bold text-center mb-5"></p><div id="cato" class="flex flex-wrap justify-center gap-2 mb-3"></div><div id="catf" class="text-center font-bold mb-2"></div><button id="catn" class="w-full bg-[#C8C8C0] hover:bg-[#B8B8B0] text-[#1C1C1E] font-semibold py-2.5 rounded-xl text-sm">ახალი</button><div class="text-center mt-2 text-sm"><span class="text-[#C8C8C0] font-bold">ქულა: <span id="cats">0</span></span></div>`;
      function nw(){const c=cats[Math.floor(Math.random()*cats.length)];document.getElementById('catw').textContent=c.name+' ('+c.ka+')';document.getElementById('catf').innerHTML='';const all=sh([...c.words,...c.wrong]);const d=document.getElementById('cato');d.innerHTML='';let picked=0;all.forEach(w=>{const b=h('button','px-3 py-2 rounded-lg border border-[#2E2E30] bg-[#242426] hover:bg-[#2E2E30] text-[#F5F5F0] transition-colors font-medium text-xs sm:text-sm',w);b.onclick=()=>{if(c.words.includes(w)){snd(1);b.classList.add('bg-[#C8C8C0]/15','border-[#C8C8C0]','pointer-events-none');picked++;if(picked>=c.words.length){sc++;document.getElementById('cats').textContent=sc;checkRecord('categories',sc);document.getElementById('catf').innerHTML='<p class="text-[#C8C8C0] text-sm">ყველა იპოვე!</p>';}}else{snd(0);b.classList.add('bg-[#ef4444]/15','pointer-events-none');}};d.appendChild(b);});}
      document.getElementById('catn').onclick=nw;nw();
    }

    function buildCatch(){
      const gc=gameWrap('სიტყვის დაჭერა','დააჭირე სწორ თარგმანს','wordcatch');let sc=0,miss=0,active=true,word,interval;
      gc.innerHTML=`<div class="text-center mb-3"><p class="text-sm">თარგმნე: <span id="cww" class="text-[#C8C8C0] font-bold"></span></p></div><div id="cwf" class="relative w-full h-48 sm:h-64 bg-white rounded-xl overflow-hidden border border-[#2E2E30] mb-3"></div><div id="cwfb" class="text-center font-bold mb-2"></div><div class="text-center text-sm"><span class="text-[#C8C8C0] font-bold">ქულა: <span id="cws">0</span></span> <span class="text-[#ef4444] ml-3">გაშვებული: <span id="cwm">0</span></span></div><button id="cwn" class="mt-3 w-full bg-[#C8C8C0] hover:bg-[#B8B8B0] text-[#1C1C1E] font-semibold py-2.5 rounded-xl text-sm">ახალი</button>`;
      function nw(){active=true;word=rw();document.getElementById('cww').textContent=word.en;document.getElementById('cwfb').innerHTML='';const field=document.getElementById('cwf');field.innerHTML='';const wrongs=sh(W.filter(w=>w.en!==word.en)).slice(0,5);const all=sh([word,...wrongs]);if(interval)clearInterval(interval);let spawned=0;interval=setInterval(()=>{if(!active||spawned>=all.length){clearInterval(interval);return;}const w=all[spawned];spawned++;const btn=document.createElement('button');btn.className='absolute px-3 py-2 rounded-lg bg-[#242426] hover:bg-[#C8C8C0]/15 font-medium text-xs transition-colors whitespace-nowrap';btn.textContent=w.ka;btn.style.left=Math.random()*60+'%';btn.style.top='-36px';field.appendChild(btn);let pos=-36;const fall=setInterval(()=>{pos+=1.5;btn.style.top=pos+'px';if(pos>220){clearInterval(fall);if(w.en===word.en&&active){miss++;document.getElementById('cwm').textContent=miss;}btn.remove();}},30);btn.onclick=()=>{clearInterval(fall);if(w.en===word.en){snd(1);sc++;document.getElementById('cws').textContent=sc;checkRecord('wordcatch',sc);btn.remove();active=false;document.getElementById('cwfb').innerHTML='<p class="text-[#C8C8C0] text-sm">დაიჭირე!</p>';setTimeout(nw,800);}else{snd(0);btn.classList.add('bg-[#ef4444]/15','pointer-events-none');}};},800);}
      document.getElementById('cwn').onclick=()=>{if(interval)clearInterval(interval);nw();};
      nw();
    }
  </script>
</Layout>
