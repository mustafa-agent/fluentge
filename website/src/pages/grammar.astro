---
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

const grammarDir = path.resolve('..', 'content', 'grammar');
const files = fs.readdirSync(grammarDir).filter(f => f.endsWith('.json')).sort();
const lessons = files.map(f => JSON.parse(fs.readFileSync(path.join(grammarDir, f), 'utf-8')));

const grouped: Record<string, typeof lessons> = {};
for (const lesson of lessons) {
  const level = lesson.level || 'A1';
  if (!grouped[level]) grouped[level] = [];
  grouped[level].push(lesson);
}
const levels = Object.keys(grouped).sort();

// Build ordered lesson list for sequential unlock
const allLessonsOrdered: typeof lessons = [];
for (const level of levels) {
  allLessonsOrdered.push(...grouped[level]);
}

// Free grammar: first 3 A1 lessons only
const FREE_GRAMMAR_SLUGS = ['to-be', 'articles', 'plural-nouns', 'present-simple', 'present-continuous', 'subject-pronouns', 'possessive-adjectives', 'prepositions-of-place'];
function isLessonFree(slug: string) {
  return FREE_GRAMMAR_SLUGS.includes(slug);
}
---

<Layout title="გრამატიკა — FluentGe">
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1456513080510-7bf3a84b82f8?w=1400&q=80" alt="" class="w-full h-full object-cover opacity-30"/>
      <div class="absolute inset-0 bg-gradient-to-b from-[#1C1C1E]/60 to-[#1C1C1E]"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 pt-24 pb-16 text-center">
      <h1 class="font-['Playfair_Display',serif] text-3xl sm:text-4xl md:text-5xl mb-4 leading-tight">გრამატიკა</h1>
      <p class="text-base sm:text-lg text-[#A0A09A] max-w-xl mx-auto">ისწავლე ინგლისური გრამატიკა ნაბიჯ-ნაბიჯ</p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-16">

    <!-- Grammar Review CTA (shown when user has completed lessons) -->
    <div id="grammar-review-cta" class="grammar-review-cta hidden" style="cursor:pointer;">
      <div class="grammar-review-icon">🔄</div>
      <div class="flex-1">
        <div class="flex items-center gap-2 mb-0.5">
          <span class="font-bold text-lg">გრამატიკის გამეორება</span>
          <span class="grammar-review-count" id="grammar-review-count">0</span>
        </div>
        <p class="text-sm text-[#A0A09A]">გაიმეორე გავლილი გაკვეთილები — განამტკიცე ცოდნა</p>
      </div>
      <span class="text-2xl">→</span>
    </div>

    {levels.map(level => (
      <div class="mb-12">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-3">
          <span class={`px-3 py-1 rounded-full text-sm font-bold ${level === 'A1' ? 'bg-green-500/20 text-green-400' : level === 'A2' ? 'bg-blue-500/20 text-blue-400' : level === 'B1' ? 'bg-yellow-500/20 text-yellow-400' : level === 'B2' ? 'bg-orange-500/20 text-orange-400' : 'bg-purple-500/20 text-purple-400'}`}>{level}</span>
          <span>{level === 'A1' ? 'დამწყები' : level === 'A2' ? 'ელემენტარული' : level === 'B1' ? 'საშუალო' : level === 'B2' ? 'საშუალო+' : level === 'C1' ? 'მოწინავე' : level}</span>
        </h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {grouped[level].map(lesson => {
            const free = isLessonFree(lesson.slug);
            const globalIdx = allLessonsOrdered.indexOf(lesson);
            return (
              <a href={free ? `/grammar/${lesson.slug}/` : '/premium/'} 
                 class={`grammar-lesson-card block border border-b-4 rounded-xl p-5 transition-all ${free ? 'bg-[#242426] hover:bg-[#2E2E30] border-[#2E2E30] border-b-[#1a1a1c] hover:scale-[1.02] active:border-b-2 active:mt-[2px]' : 'bg-[#242426] border-white/5 border-b-[#1a1a1c] opacity-60 hover:opacity-80 hover:border-amber-500/30'}`}
                 data-slug={lesson.slug}
                 data-idx={globalIdx}
                 data-free={free ? 'true' : 'false'}
                 data-lesson-url={`/grammar/${lesson.slug}/`}>
                <div class="flex items-start justify-between mb-2">
                  <div class="flex items-center gap-2">
                    <span class="grammar-lesson-status text-xl" data-status-idx={globalIdx}>📖</span>
                    <h3 class="font-semibold text-lg">{lesson.title_ka}</h3>
                  </div>
                  <div class="flex items-center gap-1">
                    <span class="grammar-lesson-badge text-xs px-2 py-0.5 rounded-full font-medium" data-badge-idx={globalIdx}>
                      {free ? '✅ უფასო' : '🔒'}
                    </span>
                    <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${level === 'A1' ? 'bg-green-500/20 text-green-400' : level === 'A2' ? 'bg-blue-500/20 text-blue-400' : level === 'B1' ? 'bg-yellow-500/20 text-yellow-400' : level === 'B2' ? 'bg-orange-500/20 text-orange-400' : 'bg-purple-500/20 text-purple-400'}`}>{level}</span>
                  </div>
                </div>
                <p class="text-[#6B6B65] text-sm">{lesson.title_en}</p>
                <div class="grammar-lesson-footer mt-3 text-xs text-[#6B6B65]" data-footer-idx={globalIdx}>
                  📝 {lesson.exercises.length} სავარჯიშო
                </div>
              </a>
            );
          })}
        </div>
      </div>
    ))}

    <!-- Premium CTA -->
    <div class="mt-8 bg-gradient-to-r from-amber-500/10 to-orange-500/10 border border-amber-500/20 rounded-2xl p-8 text-center">
      <h3 class="text-2xl font-bold mb-2">🔓 გახსენი ყველა გაკვეთილი</h3>
      <p class="text-[#6B6B65] mb-6">65 გრამატიკის გაკვეთილი, A1-დან C1-მდე, ყველა კატეგორია</p>
      <a href="/premium/" class="inline-block bg-amber-500 hover:bg-amber-400 text-white font-bold py-3 px-8 rounded-xl text-lg transition-colors border-b-4 border-amber-700 active:border-b-2 active:mt-[2px]">
        დაიწყე პრემიუმი
      </a>
    </div>
  </section>

  <script>
    // Grammar Review CTA
    (function() {
      try {
        var completed = JSON.parse(localStorage.getItem('fluentge-grammar-completed') || '{}');
        var slugs = Object.keys(completed);
        if (slugs.length >= 3) {
          var cta = document.getElementById('grammar-review-cta');
          var count = document.getElementById('grammar-review-count');
          if (cta) {
            cta.classList.remove('hidden');
            count.textContent = slugs.length;
            // Pick lesson that needs review most (SRS-like: least recently reviewed first)
            cta.addEventListener('click', function() {
              var reviews = {};
              try { reviews = JSON.parse(localStorage.getItem('fluentge-grammar-reviews') || '{}'); } catch(e) {}
              // Sort: never reviewed first, then oldest review date
              var sorted = slugs.slice().sort(function(a, b) {
                var da = reviews[a] ? new Date(reviews[a]).getTime() : 0;
                var db = reviews[b] ? new Date(reviews[b]).getTime() : 0;
                return da - db;
              });
              // Pick from top 3 least-reviewed (some randomness)
              var pick = sorted[Math.floor(Math.random() * Math.min(3, sorted.length))];
              window.location.href = '/grammar/' + pick + '/?review=1';
            });
          }
        }
      } catch(e) {}
    })();

    // Sequential Lock/Unlock System
    (function() {
      var isPremium = localStorage.getItem('fluentge-premium') === 'true';
      var completed = {};
      try { completed = JSON.parse(localStorage.getItem('fluentge-grammar-completed') || '{}'); } catch(e) {}
      
      // Get all lesson slugs in order
      var allSlugs = [];
      document.querySelectorAll('.grammar-lesson-card').forEach(function(card) {
        allSlugs.push(card.dataset.slug);
      });
      
      // Determine each lesson's state: completed, current (unlocked), or locked
      var foundFirstIncomplete = false;
      
      document.querySelectorAll('.grammar-lesson-card').forEach(function(card) {
        var slug = card.dataset.slug;
        var idx = parseInt(card.dataset.idx);
        var isFree = card.dataset.free === 'true';
        var isCompleted = !!completed[slug];
        var statusEl = card.querySelector('.grammar-lesson-status');
        var badgeEl = card.querySelector('.grammar-lesson-badge');
        var footerEl = card.querySelector('.grammar-lesson-footer');
        
        if (isCompleted) {
          // ✅ Completed state
          statusEl.textContent = '✅';
          badgeEl.textContent = 'გავლილი';
          badgeEl.className = 'grammar-lesson-badge text-xs px-2 py-0.5 rounded-full font-medium bg-green-500/20 text-green-400';
          card.classList.remove('opacity-60');
          card.classList.add('hover:scale-[1.02]');
          card.style.borderLeftColor = 'rgba(34, 197, 94, 0.3)';
          card.style.borderLeftWidth = '3px';
          card.setAttribute('href', '/grammar/' + slug + '/');
          footerEl.innerHTML = '✅ გავლილი · 📝 ' + footerEl.textContent.match(/\d+/)?.[0] + ' სავარჯიშო';
        } else if (!foundFirstIncomplete && (isFree || isPremium)) {
          // ▶ Current lesson (first incomplete that's accessible)
          foundFirstIncomplete = true;
          statusEl.textContent = '▶️';
          badgeEl.textContent = '📍 მიმდინარე';
          badgeEl.className = 'grammar-lesson-badge text-xs px-2 py-0.5 rounded-full font-medium bg-sky-500/20 text-sky-400 animate-pulse';
          card.classList.remove('opacity-60');
          card.classList.add('hover:scale-[1.02]');
          card.style.borderColor = 'rgba(56, 189, 248, 0.3)';
          card.style.boxShadow = '0 0 15px rgba(56, 189, 248, 0.1)';
          card.setAttribute('href', '/grammar/' + slug + '/');
          footerEl.innerHTML = '▶️ დაიწყე ახლა';
          footerEl.classList.remove('text-[#6B6B65]');
          footerEl.classList.add('text-sky-400', 'font-medium');
        } else if (!isCompleted && !isPremium && !isFree) {
          // 🔒 Locked (premium required)
          foundFirstIncomplete = true;
          statusEl.textContent = '🔒';
          badgeEl.textContent = '🔒 პრემიუმი';
          badgeEl.className = 'grammar-lesson-badge text-xs px-2 py-0.5 rounded-full font-medium bg-amber-500/20 text-amber-400';
          footerEl.innerHTML = '🔒 გახსნა → პრემიუმი';
          footerEl.classList.remove('text-[#6B6B65]');
          footerEl.classList.add('text-amber-400');
        } else if (!isCompleted) {
          // 🔒 Locked (sequential — need to complete previous first)
          foundFirstIncomplete = true;
          statusEl.textContent = '🔒';
          badgeEl.textContent = '🔒 ჩაკეტილი';
          badgeEl.className = 'grammar-lesson-badge text-xs px-2 py-0.5 rounded-full font-medium bg-neutral-500/20 text-neutral-400';
          card.classList.add('opacity-50');
          card.classList.remove('hover:scale-[1.02]');
          card.style.pointerEvents = 'none';
          footerEl.innerHTML = '🔒 ჯერ წინა გაკვეთილი გაიარე';
          footerEl.classList.remove('text-[#6B6B65]');
          footerEl.classList.add('text-neutral-500');
        }
      });
    })();
    
  </script>
</Layout>
