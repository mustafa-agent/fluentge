---
import Layout from '../layouts/Layout.astro';
import { readFileSync } from 'fs';
import { resolve } from 'path';

// Load words from JSON instead of hardcoding 365 words inline
const wordsPath = resolve(process.cwd(), 'public/data/words-of-day.json');
const wordsOfDay = JSON.parse(readFileSync(wordsPath, 'utf8'));
const dayOfYear = Math.floor((Date.now() - new Date(new Date().getFullYear(), 0, 0).getTime()) / 86400000);
const todayWord = wordsOfDay[dayOfYear % wordsOfDay.length];
---

<Layout title="FluentGe — ისწავლე ინგლისური ქართულად" description="უფასო ინგლისური ენის შესწავლა ქართველებისთვის. 5,250+ სიტყვა, 122 კატეგორია, 48 თამაში, 35 პოდკასტი, 65 გრამატიკის გაკვეთილი — ყველაფერი ერთ ადგილას.">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "FluentGe",
    "url": "https://fluentge.pages.dev",
    "description": "უფასო ინგლისური ენის შესწავლა ქართველებისთვის — 5,250+ სიტყვა, 122 კატეგორია, 48 თამაში, 35 პოდკასტი, 65 გრამატიკა",
    "applicationCategory": "EducationalApplication",
    "operatingSystem": "Web",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "GEL" },
    "inLanguage": ["ka", "en"],
    "availableLanguage": [
      { "@type": "Language", "name": "Georgian" },
      { "@type": "Language", "name": "English" }
    ]
  })} />

  <!-- SRS Reminder Banner (cross-page, shown by JS when due cards exist) -->
  <div id="srs-reminder-banner" class="srs-reminder-banner" style="display:none;">
    <div class="srs-reminder-inner">
      <span class="srs-reminder-icon">🧠</span>
      <span class="srs-reminder-text"><strong id="srs-due-count">0</strong> ბარათი გადასახედია</span>
      <a href="/flashcards/#srs" class="srs-reminder-link">გადახედე →</a>
      <button id="srs-reminder-close" class="srs-reminder-close" aria-label="დახურვა">✕</button>
    </div>
  </div>

  <!-- Hero: New Users -->
  <section id="hero-new" class="relative overflow-hidden">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1481627834876-b7833e8f5570?w=1400&q=80" alt="" class="w-full h-full object-cover opacity-20"/>
      <div class="absolute inset-0 bg-gradient-to-b from-[#1C1C1E]/95 to-[#1C1C1E]"></div>
    </div>
    <div class="relative max-w-3xl mx-auto px-4 pt-28 pb-24 sm:pt-36 sm:pb-32 text-center">
      <div class="inline-block mb-5 bg-green-500/10 border border-green-500/20 text-green-400 text-xs font-bold uppercase tracking-wider px-4 py-1.5 rounded-full">
        🇬🇪 #1 ინგლისურის პლატფორმა ქართველებისთვის
      </div>
      <h1 class="font-['Playfair_Display',serif] text-3xl sm:text-5xl md:text-6xl mb-5 leading-tight">
        ისწავლე ინგლისური<br/>
        <span class="bg-gradient-to-r from-sky-400 to-green-400 bg-clip-text text-transparent">სახალისოდ და უფასოდ</span>
      </h1>
      <p class="text-base sm:text-lg text-[#D0D0CA] mb-8 max-w-xl mx-auto">
        ფლეშბარათები, გრამატიკა, პოდკასტი და თამაშები — ყველაფერი ერთ ადგილას.
      </p>
      <div class="flex flex-wrap justify-center gap-2 mb-8 text-xs">
        <span class="bg-sky-500/10 border border-sky-500/20 text-sky-300 px-3 py-1.5 rounded-full font-medium">📚 5,250+ სიტყვა</span>
        <span class="bg-indigo-500/10 border border-indigo-500/20 text-indigo-300 px-3 py-1.5 rounded-full font-medium">📖 122 კატეგორია</span>
        <span class="bg-amber-500/10 border border-amber-500/20 text-amber-300 px-3 py-1.5 rounded-full font-medium">✏️ 65 გრამატიკა</span>
        <span class="bg-rose-500/10 border border-rose-500/20 text-rose-300 px-3 py-1.5 rounded-full font-medium">🎙️ 35 პოდკასტი</span>
      </div>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/flashcards/" class="bg-green-500 text-white font-bold px-8 py-3.5 rounded-xl text-base border-b-4 border-green-600 hover:bg-green-400 active:border-b-0 active:mt-1 transition-all uppercase tracking-wide">დაიწყე სწავლა</a>
        <a href="/about/" class="bg-white/10 border border-white/20 font-semibold px-8 py-3.5 rounded-xl text-base hover:bg-white/20 transition-colors">გაიგე მეტი</a>
      </div>
    </div>
  </section>

  <!-- Hero: Returning Users (hidden by default, shown by JS) -->
  <section id="hero-returning" class="relative overflow-hidden" style="display:none;">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-gradient-to-br from-sky-900/30 via-[#1C1C1E] to-green-900/20"></div>
    </div>
    <div class="relative max-w-3xl mx-auto px-4 pt-28 pb-16 sm:pt-36 sm:pb-20 text-center">
      <h1 class="font-['Playfair_Display',serif] text-2xl sm:text-4xl mb-2 leading-tight">
        გამარჯობა! 👋
      </h1>
      <p class="text-[#A0A09A] text-sm sm:text-base mb-6">მზად ხარ დღევანდელი გაკვეთილისთვის?</p>

      <!-- Stats Pills -->
      <div class="flex flex-wrap justify-center gap-3 mb-8">
        <div class="returning-stat-pill bg-orange-500/10 border border-orange-500/20">
          <span class="streak-fire">🔥</span>
          <span class="text-orange-400 font-bold" id="ret-streak">0</span>
          <span class="text-orange-400/70 text-xs">სერია</span>
        </div>
        <div class="returning-stat-pill bg-yellow-500/10 border border-yellow-500/20">
          <span>⭐</span>
          <span class="text-yellow-400 font-bold" id="ret-xp">0</span>
          <span class="text-yellow-400/70 text-xs">XP</span>
        </div>
        <div class="returning-stat-pill bg-green-500/10 border border-green-500/20">
          <span>📚</span>
          <span class="text-green-400 font-bold" id="ret-words">0</span>
          <span class="text-green-400/70 text-xs">სიტყვა</span>
        </div>
        <div class="returning-stat-pill bg-sky-500/10 border border-sky-500/20">
          <span>🏆</span>
          <span class="text-sky-400 font-bold" id="ret-level">1</span>
          <span class="text-sky-400/70 text-xs">დონე</span>
        </div>
      </div>

      <!-- Daily Lesson CTA -->
      <a href="/flashcards/#daily-lesson" class="daily-lesson-hero-cta group">
        <div class="daily-lesson-hero-icon">🎯</div>
        <div class="flex-1 text-left">
          <div class="font-bold text-base sm:text-lg">დღის გაკვეთილი</div>
          <div class="text-green-200/70 text-xs sm:text-sm">~5 წთ · ვოკაბულარი, გრამატიკა, მოსმენა</div>
        </div>
        <div class="text-2xl group-hover:translate-x-1 transition-transform">▶</div>
      </a>

      <!-- SRS Due reminder inside returning hero -->
      <div id="ret-srs-due" class="mt-4 text-sm text-amber-400/80" style="display:none;">
        🧠 <span id="ret-srs-count">0</span> ბარათი გადასახედია — <a href="/flashcards/#srs" class="underline hover:text-amber-300">გადახედე</a>
      </div>
    </div>
  </section>

  <!-- Homepage Personalization Script -->
  <script is:inline>
    (function() {
      var xp = parseInt(localStorage.getItem('totalXP') || '0', 10);
      var streak = parseInt(localStorage.getItem('currentStreak') || '0', 10);
      // Show returning hero if user has any progress
      if (xp > 0 || streak > 0) {
        var heroNew = document.getElementById('hero-new');
        var heroRet = document.getElementById('hero-returning');
        if (heroNew) heroNew.style.display = 'none';
        if (heroRet) heroRet.style.display = 'block';
        // Populate stats
        var xpStr = xp >= 1000 ? (xp/1000).toFixed(1) + 'k' : xp.toString();
        var el;
        el = document.getElementById('ret-streak'); if(el) el.textContent = streak;
        el = document.getElementById('ret-xp'); if(el) el.textContent = xpStr;
        // Count learned words from SRS stores
        var words = 0;
        for (var i = 0; i < localStorage.length; i++) {
          var k = localStorage.key(i);
          if (k && k.startsWith('fluentge-srs-')) {
            try {
              var store = JSON.parse(localStorage.getItem(k));
              words += Object.keys(store || {}).length;
            } catch(e) {}
          }
        }
        el = document.getElementById('ret-words'); if(el) el.textContent = words;
        var level = Math.floor(xp / 200) + 1;
        el = document.getElementById('ret-level'); if(el) el.textContent = level;
      }
      // SRS due count (for both banners)
      var totalDue = 0;
      var now = Date.now();
      for (var j = 0; j < localStorage.length; j++) {
        var key = localStorage.key(j);
        if (key && key.startsWith('fluentge-srs-')) {
          try {
            var srs = JSON.parse(localStorage.getItem(key));
            for (var cardId in srs) {
              if (srs[cardId] && srs[cardId].nextReview && srs[cardId].nextReview <= now) totalDue++;
            }
          } catch(e) {}
        }
      }
      if (totalDue > 0) {
        // Show SRS line in returning hero
        var retSrs = document.getElementById('ret-srs-due');
        if (retSrs) { retSrs.style.display = 'block'; }
        var retSrsCount = document.getElementById('ret-srs-count');
        if (retSrsCount) retSrsCount.textContent = totalDue;
        // Show cross-page SRS banner (only on non-flashcard pages)
        if (window.location.pathname.indexOf('/flashcards') === -1) {
          var dismissed = sessionStorage.getItem('srs-banner-dismissed');
          if (!dismissed) {
            var banner = document.getElementById('srs-reminder-banner');
            if (banner) banner.style.display = 'block';
            var dueEl = document.getElementById('srs-due-count');
            if (dueEl) dueEl.textContent = totalDue;
          }
        }
      }
      // SRS banner close
      var closeBtn = document.getElementById('srs-reminder-close');
      if (closeBtn) {
        closeBtn.addEventListener('click', function() {
          var b = document.getElementById('srs-reminder-banner');
          if (b) b.style.display = 'none';
          sessionStorage.setItem('srs-banner-dismissed', '1');
        });
      }
    })();
  </script>

  <!-- Onboarding CTA — Direct to Top 2000 -->
  <section class="px-4 pt-10 pb-2 max-w-2xl mx-auto" id="onboarding-cta">
    <!-- Primary: Top 2000 Hero CTA -->
    <div class="bg-gradient-to-br from-amber-500/15 via-orange-500/10 to-yellow-500/15 border border-amber-500/30 rounded-2xl p-6 sm:p-8 relative overflow-hidden mb-4">
      <div class="absolute -top-6 -right-6 text-[80px] opacity-10 select-none">⭐</div>
      <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-amber-400 via-orange-400 to-yellow-400"></div>
      <div class="flex flex-col sm:flex-row items-center gap-5">
        <div class="flex-shrink-0">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center text-3xl shadow-lg shadow-amber-500/20">⭐</div>
        </div>
        <div class="flex-1 text-center sm:text-left">
          <div class="flex items-center gap-2 justify-center sm:justify-start mb-1">
            <span class="text-[10px] font-bold uppercase tracking-wider bg-green-500/20 text-green-400 px-2 py-0.5 rounded-full">უფასო</span>
            <span class="text-[10px] font-bold uppercase tracking-wider bg-amber-500/20 text-amber-400 px-2 py-0.5 rounded-full">🔥 #1 პოპულარული</span>
          </div>
          <h3 class="text-lg sm:text-xl font-bold mb-1">ტოპ 2000 ინგლისური სიტყვა</h3>
          <p class="text-[#A0A09A] text-sm mb-3">ეს 2000 სიტყვა ყოველდღიური ინგლისურის 80%-ს ფარავს. დაიწყე აქედან!</p>
          <a href="/flashcards/#study/top-2000/srs" class="inline-block bg-amber-500 text-white font-bold px-6 py-2.5 rounded-xl text-sm border-b-4 border-amber-600 hover:bg-amber-400 active:border-b-0 active:mt-0.5 transition-all">
            🚀 დაიწყე სწავლა
          </a>
        </div>
      </div>
    </div>
    <!-- Secondary: Other paths -->
    <div class="flex flex-wrap gap-2 justify-center">
      <a href="/grammar/" class="bg-sky-500/10 border border-sky-500/20 text-sky-400 font-semibold px-5 py-2.5 rounded-xl text-sm hover:bg-sky-500/20 transition-colors">
        ✏️ გრამატიკა A1
      </a>
      <a href="/games/" class="bg-purple-500/10 border border-purple-500/20 text-purple-400 font-semibold px-5 py-2.5 rounded-xl text-sm hover:bg-purple-500/20 transition-colors">
        🎮 თამაშები
      </a>
      <a href="/flashcards/" class="bg-white/5 border border-white/10 text-[#A0A09A] font-semibold px-5 py-2.5 rounded-xl text-sm hover:bg-white/10 transition-colors">
        📚 ყველა კატეგორია
      </a>
    </div>
  </section>

  <!-- Word of the Day -->
  <section class="px-4 py-10 max-w-2xl mx-auto">
    <div class="bg-[#242426] border border-[#2E2E30] rounded-2xl p-6 text-center relative overflow-hidden">
      <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-sky-400 via-green-400 to-amber-400"></div>
      <div class="flex items-center justify-center gap-2 mb-2 mt-1">
        <span class="text-lg">✨</span>
        <p class="text-xs text-[#6B6B65] uppercase tracking-wider font-bold">დღის სიტყვა</p>
        <span class="text-[10px] font-bold bg-sky-500/20 text-sky-300 px-2 py-0.5 rounded-full">{todayWord.level}</span>
      </div>
      <h3 class="font-['Playfair_Display',serif] text-3xl text-white mb-1">{todayWord.en}</h3>
      <p class="text-[#6B6B65] text-sm mb-1">{todayWord.pron}</p>
      <p class="text-lg text-sky-300 mb-3 font-medium">{todayWord.ka}</p>
      <div class="bg-[#1C1C1E] rounded-xl p-3 text-sm">
        <p class="text-[#A0A09A]">"{todayWord.example}"</p>
        <p class="text-[#6B6B65] mt-1">{todayWord.exampleKa}</p>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="px-4 py-16 max-w-5xl mx-auto">
    <h2 class="font-['Playfair_Display',serif] text-2xl sm:text-3xl text-center mb-3">რას გთავაზობთ</h2>
    <p class="text-center text-[#6B6B65] text-sm mb-12">აირჩიე სწავლის მეთოდი</p>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {[
        { href: "/flashcards/", img: "https://images.unsplash.com/photo-1456513080510-7bf3a84b82f8?w=400&q=60", icon: "📚", title: "ფლეშბარათები", desc: "5,250+ სიტყვა 122 კატეგორიაში.", cta: "დაიწყე", color: "sky" },
        { href: "/grammar/", img: "https://images.unsplash.com/photo-1471107340929-a87cd0f5b5f3?w=400&q=60", icon: "✏️", title: "გრამატიკა", desc: "65 გაკვეთილი A1-დან C1-მდე.", cta: "დაიწყე", color: "green" },
        { href: "/podcast/", img: "https://images.unsplash.com/photo-1478737270239-2f02b77fc618?w=400&q=60", icon: "🎙️", title: "პოდკასტი", desc: "30 ეპიზოდი რეალური დიალოგებით.", cta: "მოისმინე", color: "rose" },
        { href: "/phrases/", img: "https://images.unsplash.com/photo-1543165796-5426273eaab3?w=400&q=60", icon: "💬", title: "ფრაზები", desc: "1,695 ფრაზა 40 კატეგორიაში 🔊", cta: "ნახე", color: "amber" },
        { href: "/games/", img: "https://images.unsplash.com/photo-1606326608606-aa0b62935f2b?w=400&q=60", icon: "🎮", title: "თამაშები", desc: "48 ინტერაქტიული თამაში.", cta: "ითამაშე", color: "indigo" },
        { href: "/blog/", img: "https://images.unsplash.com/photo-1519682577862-22b62b24e493?w=400&q=60", icon: "📝", title: "ბლოგი", desc: "სტატიები და რჩევები.", cta: "წაიკითხე", color: "neutral" },
      ].map(item => (
        <a href={item.href} class="group bg-[#242426] border border-[#2E2E30] rounded-2xl overflow-hidden hover:border-[#404040] transition-all hover:-translate-y-1 hover:shadow-lg hover:shadow-black/20">
          <div class="h-36 overflow-hidden relative">
            <img src={item.img} alt="" class="w-full h-full object-cover opacity-60 group-hover:opacity-80 group-hover:scale-105 transition-all duration-500"/>
            <div class="absolute top-3 left-3 text-2xl bg-[#242426]/80 backdrop-blur-sm w-10 h-10 rounded-xl flex items-center justify-center">{item.icon}</div>
          </div>
          <div class="p-5">
            <h3 class="font-bold text-base mb-1">{item.title}</h3>
            <p class="text-[#6B6B65] text-sm">{item.desc}</p>
            <span class="inline-block mt-3 text-sky-400 text-sm font-medium group-hover:translate-x-1 transition-transform">{item.cta} &rarr;</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Social Proof -->
  <section class="px-4 py-16 max-w-4xl mx-auto">
    <h2 class="font-['Playfair_Display',serif] text-2xl sm:text-3xl text-center mb-3">რას ამბობენ მომხმარებლები</h2>
    <p class="text-center text-[#6B6B65] text-sm mb-10">ათასობით ქართველი უკვე სწავლობს FluentGe-ით</p>
    
    <div class="grid sm:grid-cols-3 gap-5 mb-12">
      {[
        { name: "ნინო მ.", avatar: "👩‍🎓", text: "ფლეშბარათები ძალიან მეხმარება ახალი სიტყვების დამახსოვრებაში. დღეში 15 წუთი და უკვე თვალსაჩინო პროგრესი მაქვს!", stars: 5 },
        { name: "გიორგი კ.", avatar: "👨‍💻", text: "თამაშებით სწავლა ბევრად უფრო სახალისოა ვიდრე წიგნით. განსაკუთრებით Word Search მომწონს!", stars: 5 },
        { name: "მარიამ ლ.", avatar: "👩‍🏫", text: "გრამატიკის გაკვეთილები ძალიან კარგად არის ახსნილი. ქართულად რომ არის ყველაფერი, ეს საუკეთესოა!", stars: 4 },
      ].map(review => (
        <div class="bg-[#242426] border border-[#2E2E30] rounded-2xl p-5 hover:border-[#404040] transition-colors">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-sky-400 to-green-400 flex items-center justify-center text-lg">{review.avatar}</div>
            <div>
              <div class="font-semibold text-sm">{review.name}</div>
              <div class="text-yellow-400 text-xs">{'⭐'.repeat(review.stars)}{review.stars < 5 ? '☆' : ''}</div>
            </div>
          </div>
          <p class="text-[#A0A09A] text-sm leading-relaxed">"{review.text}"</p>
        </div>
      ))}
    </div>

    <!-- Why FluentGe -->
    <div class="grid sm:grid-cols-2 gap-5">
      {[
        { icon: "🇬🇪", title: "ქართულად", desc: "ყველაფერი შენს ენაზე — არანაირი ინგლისურ-ინგლისური ახსნა" },
        { icon: "🆓", title: "სრულიად უფასო", desc: "5,250+ სიტყვა, 48 თამაში, 65 გრამატიკა — ფული არ გჭირდება" },
        { icon: "🎮", title: "სახალისო სწავლა", desc: "თამაშები, XP, სერიები — სწავლა არასდროს ყოფილა ასეთი სახალისო" },
