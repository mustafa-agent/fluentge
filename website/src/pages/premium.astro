---
import Layout from '../layouts/Layout.astro';
---

<Layout title="პრემიუმი — FluentGe">
  <style>
    .premium-hero {
      background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #0f172a 100%);
      position: relative;
      overflow: hidden;
    }
    .premium-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 50% 0%, rgba(99,102,241,0.15) 0%, transparent 60%);
    }
    .gradient-text {
      background: linear-gradient(135deg, #818cf8 0%, #c084fc 50%, #f472b6 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .pricing-card {
      background: #1e1e22;
      border: 1px solid #2e2e32;
      border-radius: 1.25rem;
      padding: 2rem;
      text-align: center;
      transition: all 0.3s;
    }
    .pricing-card:hover {
      border-color: #4a4a50;
      transform: translateY(-2px);
    }
    .pricing-card.popular {
      border: 2px solid #818cf8;
      background: linear-gradient(180deg, #1e1b4b 0%, #1e1e22 40%);
      position: relative;
      transform: scale(1.03);
    }
    .pricing-card.popular:hover {
      transform: scale(1.03) translateY(-2px);
    }
    .popular-badge {
      position: absolute;
      top: -14px;
      left: 50%;
      transform: translateX(-50%);
      background: linear-gradient(135deg, #818cf8, #c084fc);
      color: white;
      font-size: 0.75rem;
      font-weight: 700;
      padding: 4px 16px;
      border-radius: 9999px;
      white-space: nowrap;
    }
    .price-amount {
      font-size: 3rem;
      font-weight: 800;
      color: white;
      line-height: 1;
    }
    .feature-check {
      color: #818cf8;
      flex-shrink: 0;
    }
    .cta-btn {
      display: block;
      width: 100%;
      padding: 14px;
      border-radius: 0.75rem;
      font-weight: 700;
      font-size: 0.95rem;
      cursor: pointer;
      transition: all 0.2s;
      border: none;
      border-bottom: 4px solid transparent;
    }
    .cta-btn.primary {
      background: linear-gradient(135deg, #818cf8, #6366f1);
      color: white;
      border-bottom-color: #4f46e5;
    }
    .cta-btn.primary:hover { background: linear-gradient(135deg, #6366f1, #4f46e5); }
    .cta-btn.primary:active { border-bottom-width: 2px; transform: translateY(2px); }
    .cta-btn.secondary {
      background: #2e2e32;
      color: white;
      border-bottom-color: #1a1a1e;
    }
    .cta-btn.secondary:hover { background: #3a3a3e; }
    .cta-btn.secondary:active { border-bottom-width: 2px; transform: translateY(2px); }

    /* Comparison table */
    .compare-table { width: 100%; border-collapse: collapse; }
    .compare-table th, .compare-table td {
      padding: 12px 16px;
      text-align: left;
      font-size: 0.875rem;
      border-bottom: 1px solid #2e2e32;
    }
    .compare-table th { color: #a0a0a0; font-weight: 600; }
    .compare-table td { color: #e0e0e0; }
    .compare-table td:nth-child(2), .compare-table td:nth-child(3),
    .compare-table th:nth-child(2), .compare-table th:nth-child(3) {
      text-align: center;
      width: 120px;
    }
    .compare-table tr:last-child td { border-bottom: none; }
    .check-icon { color: #22c55e; font-size: 1.1rem; }
    .cross-icon { color: #6b7280; font-size: 1.1rem; }
    .limited-text { color: #eab308; font-size: 0.75rem; font-weight: 600; }

    /* Testimonials */
    .testimonial-card {
      background: #1e1e22;
      border: 1px solid #2e2e32;
      border-radius: 1rem;
      padding: 1.5rem;
    }
    .stars { color: #eab308; }

    /* FAQ accordion */
    .faq-item { border-bottom: 1px solid #2e2e32; }
    .faq-item:last-child { border-bottom: none; }
    .faq-q {
      width: 100%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px 0;
      background: none;
      border: none;
      color: #e0e0e0;
      font-weight: 600;
      font-size: 0.95rem;
      cursor: pointer;
      text-align: left;
    }
    .faq-q:hover { color: #818cf8; }
    .faq-a {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease, padding 0.3s ease;
      color: #a0a0a0;
      font-size: 0.875rem;
      line-height: 1.6;
    }
    .faq-item.open .faq-a { max-height: 200px; padding-bottom: 16px; }
    .faq-item.open .faq-arrow { transform: rotate(180deg); }
    .faq-arrow { transition: transform 0.3s; color: #6b7280; }

    /* Stats bar */
    .stat-item { text-align: center; }
    .stat-num { font-size: 1.5rem; font-weight: 800; color: white; }
    .stat-label { font-size: 0.75rem; color: #a0a0a0; margin-top: 2px; }

    /* Light mode */
    :global(.light) .pricing-card { background: white; border-color: #e5e7eb; }
    :global(.light) .pricing-card.popular { background: linear-gradient(180deg, #eef2ff 0%, white 40%); border-color: #818cf8; }
    :global(.light) .price-amount { color: #1a1a2e; }
    :global(.light) .compare-table th { color: #6b7280; }
    :global(.light) .compare-table td { color: #374151; }
    :global(.light) .compare-table th, :global(.light) .compare-table td { border-bottom-color: #e5e7eb; }
    :global(.light) .testimonial-card { background: white; border-color: #e5e7eb; }
    :global(.light) .faq-q { color: #374151; }
    :global(.light) .faq-a { color: #6b7280; }
    :global(.light) .faq-item { border-bottom-color: #e5e7eb; }
    :global(.light) .cta-btn.secondary { background: #f3f4f6; color: #374151; border-bottom-color: #d1d5db; }
    :global(.light) .premium-hero { background: linear-gradient(135deg, #eef2ff 0%, #e0e7ff 50%, #eef2ff 100%); }
    :global(.light) .premium-hero::before { background: radial-gradient(ellipse at 50% 0%, rgba(99,102,241,0.1) 0%, transparent 60%); }
    :global(.light) .stat-num { color: #1a1a2e; }
    :global(.light) .stat-label { color: #6b7280; }
  </style>

  <!-- Hero -->
  <section class="premium-hero">
    <div class="relative max-w-4xl mx-auto px-4 pt-20 pb-16 text-center">
      <div class="inline-flex items-center gap-2 bg-indigo-500/10 border border-indigo-500/20 rounded-full px-4 py-1.5 mb-6">
        <span class="text-indigo-400 text-sm font-semibold">⭐ პრემიუმი</span>
      </div>
      <h1 class="font-['Playfair_Display',serif] text-3xl sm:text-4xl md:text-5xl mb-4 leading-tight">
        <span class="gradient-text">გახდი ფლუენტი</span>
      </h1>
      <p class="text-base sm:text-lg text-[#a0a0aa] max-w-xl mx-auto mb-10">
        განბლოკე ყველა ფუნქცია — 5,250+ სიტყვა, 65 გრამატიკის გაკვეთილი, 30 თამაში, 6 სასწავლო რეჟიმი და ბევრი სხვა
      </p>

      <!-- Stats bar -->
      <div class="flex justify-center gap-8 sm:gap-12 flex-wrap">
        <div class="stat-item"><div class="stat-num">5,250+</div><div class="stat-label">სიტყვა</div></div>
        <div class="stat-item"><div class="stat-num">65</div><div class="stat-label">გრამატიკა</div></div>
        <div class="stat-item"><div class="stat-num">30</div><div class="stat-label">თამაში</div></div>
        <div class="stat-item"><div class="stat-num">6</div><div class="stat-label">რეჟიმი</div></div>
      </div>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="max-w-4xl mx-auto px-4 py-16">
    <h2 class="text-xl sm:text-2xl font-bold text-center mb-2 gradient-text">აირჩიე შენი გეგმა</h2>
    <p class="text-sm text-[#a0a0aa] text-center mb-10">გაუქმება ნებისმიერ დროს. რისკი არ არის.</p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-3xl mx-auto items-start">
      <!-- Free -->
      <div class="pricing-card">
        <p class="text-sm font-semibold text-[#a0a0aa] uppercase tracking-wider mb-3">უფასო</p>
        <div class="price-amount mb-1">$0</div>
        <p class="text-xs text-[#6b7280] mb-6">სამუდამოდ</p>
        <ul class="text-left text-sm space-y-3 mb-8 text-[#c0c0c0]">
          <li class="flex items-center gap-2"><span class="check-icon">✓</span> 3 თამაში</li>
          <li class="flex items-center gap-2"><span class="check-icon">✓</span> საბაზისო ფლეშქარდები</li>
          <li class="flex items-center gap-2"><span class="check-icon">✓</span> 8 გრამატიკის გაკვეთილი</li>
          <li class="flex items-center gap-2"><span class="check-icon">✓</span> ყოველდღიური სიტყვა</li>
          <li class="flex items-center gap-2"><span class="cross-icon">✗</span><span class="text-[#6b7280]">პოდკასტები</span></li>
          <li class="flex items-center gap-2"><span class="cross-icon">✗</span><span class="text-[#6b7280]">რთული სიტყვები</span></li>
        </ul>
        <a href="/register/" class="cta-btn secondary">დარეგისტრირდი უფასოდ</a>
      </div>

      <!-- Yearly (popular) -->
      <div class="pricing-card popular">
        <div class="popular-badge">🔥 ყველაზე პოპულარული</div>
        <p class="text-sm font-semibold text-indigo-400 uppercase tracking-wider mb-3">წლიური</p>
        <div class="price-amount mb-1">$6<span class="text-lg text-[#a0a0aa]">.67</span></div>
        <p class="text-xs text-[#6b7280] mb-1">თვეში · $79.99/წელი</p>
        <p class="text-xs text-green-400 font-semibold mb-6">დაზოგე 33% 💰</p>
        <ul class="text-left text-sm space-y-3 mb-8 text-[#c0c0c0]">
          <li class="flex items-center gap-2"><span class="check-icon">✓</span> <strong>ყველაფერი</strong> განბლოკილი</li>
          <li class="flex items-center gap-2"><span class="check-icon">✓</span> 142 ფლეშქარდ დეკი</li>
          <li class="flex items-center gap-2"><span class="check-icon">✓</span> 65 გრამატიკის გაკვეთილი</li>
          <li class="flex items-center gap-2"><span class="check-icon">✓</span> 30 თამაში</li>
          <li class="flex items-center gap-2"><span class="check-icon">✓</span> 35 პოდკასტი</li>
          <li class="flex items-center gap-2"><span class="check-icon">✓</span> 6 სასწავლო რეჟიმი</li>
        </ul>
        <button onclick="openPaymentModal('yearly')" class="cta-btn primary">აირჩიე წლიური ⚡</button>
      </div>

      <!-- Monthly -->
      <div class="pricing-card">
        <p class="text-sm font-semibold text-[#a0a0aa] uppercase tracking-wider mb-3">თვიური</p>
        <div class="price-amount mb-1">$9<span class="text-lg text-[#a0a0aa]">.99</span></div>
        <p class="text-xs text-[#6b7280] mb-6">თვეში</p>
        <ul class="text-left text-sm space-y-3 mb-8 text-[#c0c0c0]">
          <li class="flex items-center gap-2"><span class="check-icon">✓</span> <strong>ყველაფერი</strong> განბლოკილი</li>
          <li class="flex items-center gap-2"><span class="check-icon">✓</span> 142 ფლეშქარდ დეკი</li>
          <li class="flex items-center gap-2"><span class="check-icon">✓</span> 65 გრამატიკის გაკვეთილი</li>
          <li class="flex items-center gap-2"><span class="check-icon">✓</span> 30 თამაში</li>
          <li class="flex items-center gap-2"><span class="check-icon">✓</span> 35 პოდკასტი</li>
          <li class="flex items-center gap-2"><span class="check-icon">✓</span> 6 სასწავლო რეჟიმი</li>
        </ul>
        <button onclick="openPaymentModal('monthly')" class="cta-btn secondary">აირჩიე თვიური</button>
      </div>
    </div>
  </section>

  <!-- Feature Comparison Table -->
  <section class="max-w-3xl mx-auto px-4 pb-16">
    <h2 class="text-xl font-bold text-center mb-8 gradient-text">დეტალური შედარება</h2>
    <div class="rounded-2xl overflow-hidden" style="background: #1e1e22; border: 1px solid #2e2e32;">
      <table class="compare-table">
        <thead>
          <tr style="border-bottom: 2px solid #2e2e32;">
            <th>ფუნქცია</th>
            <th>უფასო</th>
            <th style="color: #818cf8;">პრემიუმი</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>ფლეშქარდები</td><td><span class="limited-text">ლიმიტი</span></td><td><span class="check-icon">✓</span> 142 დეკი</td></tr>
          <tr><td>გრამატიკა</td><td><span class="limited-text">8 გაკვეთილი</span></td><td><span class="check-icon">✓</span> 65 გაკვეთილი</td></tr>
          <tr><td>თამაშები</td><td><span class="limited-text">3 თამაში</span></td><td><span class="check-icon">✓</span> 30 თამაში</td></tr>
          <tr><td>პოდკასტები</td><td><span class="cross-icon">✗</span></td><td><span class="check-icon">✓</span> 35 ეპიზოდი</td></tr>
          <tr><td>ქვიზ რეჟიმი</td><td><span class="check-icon">✓</span></td><td><span class="check-icon">✓</span></td></tr>
          <tr><td>აკრეფის რეჟიმი</td><td><span class="check-icon">✓</span></td><td><span class="check-icon">✓</span></td></tr>
          <tr><td>რთული სიტყვები</td><td><span class="cross-icon">✗</span></td><td><span class="check-icon">✓</span></td></tr>
          <tr><td>სიტყვების ძიება</td><td><span class="check-icon">✓</span></td><td><span class="check-icon">✓</span></td></tr>
          <tr><td>სერია & XP</td><td><span class="check-icon">✓</span></td><td><span class="check-icon">✓</span></td></tr>
          <tr><td>მიღწევები</td><td><span class="check-icon">✓</span></td><td><span class="check-icon">✓</span></td></tr>
          <tr><td>ყოველდღიური სიტყვა</td><td><span class="check-icon">✓</span></td><td><span class="check-icon">✓</span></td></tr>
          <tr><td>აუდიო გამოთქმა</td><td><span class="check-icon">✓</span></td><td><span class="check-icon">✓</span></td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="max-w-4xl mx-auto px-4 pb-16">
    <h2 class="text-xl font-bold text-center mb-2 gradient-text">რას ამბობენ მომხმარებლები</h2>
    <p class="text-sm text-[#a0a0aa] text-center mb-10">ასობით ქართველი უკვე სწავლობს FluentGe-ით</p>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      <div class="testimonial-card">
        <div class="stars mb-3">★★★★★</div>
        <p class="text-sm text-[#c0c0c0] mb-4 leading-relaxed">"ძალიან მომეწონა ფლეშქარდები და თამაშები. ყოველდღე ვიყენებ და ინგლისური ბევრად უკეთ მესმის ახლა."</p>
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-full bg-indigo-500/20 flex items-center justify-center text-indigo-400 font-bold text-sm">ნ</div>
          <div><p class="text-sm font-semibold text-white">ნინო მ.</p><p class="text-xs text-[#6b7280]">სტუდენტი, თბილისი</p></div>
        </div>
      </div>
      <div class="testimonial-card">
        <div class="stars mb-3">★★★★★</div>
        <p class="text-sm text-[#c0c0c0] mb-4 leading-relaxed">"პოდკასტები საუკეთესოა! ქართულად ხსნიან ყველაფერს და ძალიან მარტივად ვისწავლე ახალი სიტყვები."</p>
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-full bg-green-500/20 flex items-center justify-center text-green-400 font-bold text-sm">გ</div>
          <div><p class="text-sm font-semibold text-white">გიორგი კ.</p><p class="text-xs text-[#6b7280]">პროგრამისტი, ბათუმი</p></div>
        </div>
      </div>
      <div class="testimonial-card">
        <div class="stars mb-3">★★★★★</div>
        <p class="text-sm text-[#c0c0c0] mb-4 leading-relaxed">"ჩემს შვილს ძალიან უყვარს თამაშები. სახალისოდ ისწავლა 200+ სიტყვა ერთ თვეში!"</p>
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-full bg-pink-500/20 flex items-center justify-center text-pink-400 font-bold text-sm">მ</div>
          <div><p class="text-sm font-semibold text-white">მარიამ ბ.</p><p class="text-xs text-[#6b7280]">მშობელი, ქუთაისი</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-2xl mx-auto px-4 pb-20">
    <h2 class="text-xl font-bold text-center mb-8 gradient-text">ხშირად დასმული კითხვები</h2>
    <div class="rounded-2xl p-6" style="background: #1e1e22; border: 1px solid #2e2e32;">
      <div class="faq-item">
        <button class="faq-q" onclick="this.parentElement.classList.toggle('open')">
          <span>რა შედის პრემიუმ გეგმაში?</span>
          <span class="faq-arrow">▾</span>
        </button>
        <div class="faq-a">პრემიუმი მოიცავს 142 ფლეშქარდ დეკს (5,250+ სიტყვა), 65 გრამატიკის გაკვეთილს, 30 თამაშს, 35 პოდკასტს ტრანსკრიფტით, 6 სასწავლო რეჟიმს (ქვიზი, აკრეფა, რთული სიტყვები და სხვა), მიღწევებს და XP სისტემას.</div>
      </div>
      <div class="faq-item">
        <button class="faq-q" onclick="this.parentElement.classList.toggle('open')">
          <span>შემიძლია გავაუქმო ნებისმიერ დროს?</span>
          <span class="faq-arrow">▾</span>
        </button>
        <div class="faq-a">დიახ! გამოწერის გაუქმება შეგიძლია ნებისმიერ დროს. წვდომა გაგრძელდება გადახდილი პერიოდის ბოლომდე. არანაირი ჯარიმა ან დამალული საკომისიო.</div>
      </div>
      <div class="faq-item">
        <button class="faq-q" onclick="this.parentElement.classList.toggle('open')">
          <span>რა არის უფასო?</span>
          <span class="faq-arrow">▾</span>
        </button>
        <div class="faq-a">უფასო გეგმით ხელმისაწვდომია: 3 თამაში, საბაზისო ფლეშქარდები, 8 გრამატიკის გაკვეთილი (სრული A1 დონე), ყოველდღიური სიტყვა, ქვიზი და აკრეფის რეჟიმი, სერია და XP სისტემა.</div>
      </div>
      <div class="faq-item">
        <button class="faq-q" onclick="this.parentElement.classList.toggle('open')">
          <span>რომელი გადახდის მეთოდები მუშაობს?</span>
          <span class="faq-arrow">▾</span>
        </button>
        <div class="faq-a">მალე დაემატება ბარათით გადახდა (Visa/Mastercard) და ქართული ბანკით გადახდა (BOG/TBC). ამჟამად შეგიძლია დაგვიკავშირდე tokakhozre@gmail.com მეილზე.</div>
      </div>
      <div class="faq-item">
        <button class="faq-q" onclick="this.parentElement.classList.toggle('open')">
          <span>FluentGe მობილურზე მუშაობს?</span>
          <span class="faq-arrow">▾</span>
        </button>
        <div class="faq-a">დიახ! FluentGe სრულად ადაპტირებულია მობილურისთვის. შეგიძლია ისწავლო ტელეფონიდან, ტაბლეტიდან ან კომპიუტერიდან.</div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="premium-hero">
    <div class="relative max-w-2xl mx-auto px-4 py-16 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold mb-4 gradient-text">მზად ხარ?</h2>
      <p class="text-[#a0a0aa] mb-8">შეუერთდი ასობით ქართველს, რომლებიც ინგლისურს FluentGe-ით სწავლობენ</p>
      <button onclick="openPaymentModal('yearly')" class="cta-btn primary" style="max-width: 320px; margin: 0 auto;">
        დაიწყე პრემიუმით ⚡
      </button>
      <p class="text-xs text-[#6b7280] mt-4">გაუქმება ნებისმიერ დროს · უსაფრთხო გადახდა</p>
    </div>
  </section>

  <!-- Payment Modal -->
  <div class="payment-overlay" id="payment-overlay">
    <div class="payment-modal">
      <div class="plan-badge" id="modal-plan-badge">წლიური — $79.99/წელი</div>
      <h3>აირჩიე გადახდის მეთოდი</h3>
      <p>გადახდა უსაფრთხო და დაცულია. აირჩიე შენთვის მოსახერხებელი მეთოდი.</p>
      <div class="payment-options">
        <button class="pay-btn stripe" onclick="handlePayment('stripe')">
          💳 ბარათით გადახდა
        </button>
        <button class="pay-btn bog" onclick="handlePayment('bog')">
          🏦 BOG / TBC (ქართული ბანკი)
        </button>
      </div>
      <div class="secure-note">🔒 SSL დაცული · გაუქმება ნებისმიერ დროს</div>
      <button class="payment-close" onclick="closePaymentModal()">გაუქმება</button>
    </div>
  </div>

  <!-- Light mode overrides -->
  <style>
    :global(.light) .compare-table { background: white; }
    :global(.light) div[style*="background: #1e1e22"] { background: white !important; border-color: #e5e7eb !important; }
    :global(.light) .testimonial-card p.text-white, :global(.light) .testimonial-card .text-white { color: #1a1a2e !important; }
    :global(.light) .faq-a { color: #6b7280; }

    /* Payment modal */
    .payment-overlay {
      position: fixed; inset: 0;
      background: rgba(0,0,0,0.6);
      backdrop-filter: blur(4px);
      z-index: 100;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }
    .payment-overlay.show { display: flex; }
    .payment-modal {
      background: #1e1e22;
      border: 1px solid #2e2e32;
      border-radius: 1.5rem;
      padding: 2rem;
      max-width: 420px;
      width: 100%;
      text-align: center;
      animation: payModalIn 0.3s ease;
    }
    @keyframes payModalIn {
      from { transform: translateY(30px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }
    .payment-modal h3 { font-size: 1.25rem; font-weight: 700; color: white; margin-bottom: 0.5rem; }
    .payment-modal p { color: #a0a0aa; font-size: 0.85rem; margin-bottom: 1.5rem; line-height: 1.5; }
    .payment-options { display: flex; flex-direction: column; gap: 12px; margin-bottom: 1.5rem; }
    .pay-btn {
      display: flex; align-items: center; justify-content: center; gap: 10px;
      padding: 14px 20px; border-radius: 0.75rem; font-weight: 700; font-size: 0.9rem;
      cursor: pointer; border: none; border-bottom: 4px solid transparent;
      transition: all 0.2s; width: 100%;
    }
    .pay-btn:active { border-bottom-width: 2px; transform: translateY(2px); }
    .pay-btn.stripe { background: #635bff; color: white; border-bottom-color: #4f46e5; }
    .pay-btn.stripe:hover { background: #5046e5; }
    .pay-btn.bog { background: #00a651; color: white; border-bottom-color: #008c44; }
    .pay-btn.bog:hover { background: #009147; }
    .plan-badge {
      display: inline-block;
      background: linear-gradient(135deg, #818cf8, #c084fc);
      color: white; font-size: 0.75rem; font-weight: 700;
      padding: 4px 14px; border-radius: 9999px; margin-bottom: 1rem;
    }
    .secure-note {
      display: flex; align-items: center; justify-content: center;
      gap: 6px; color: #6b7280; font-size: 0.7rem; margin-top: 0.5rem;
    }
    .payment-close {
      background: none; border: none; color: #6b7280;
      font-size: 0.85rem; cursor: pointer; padding: 8px 16px; margin-top: 0.75rem;
    }
    .payment-close:hover { color: #a0a0a0; }
    :global(.light) .payment-modal { background: white; border-color: #e5e7eb; }
    :global(.light) .payment-modal h3 { color: #1a1a2e; }
    :global(.light) .payment-modal p { color: #6b7280; }
  </style>

  <script is:inline>
    (function() {
      var PREMIUM_EMAILS = ['tokakhozre@gmail.com'];
      var u = localStorage.getItem('fluentge-user');
      if (u) {
        try {
          var data = JSON.parse(u);
          if (PREMIUM_EMAILS.indexOf(data.email) !== -1) {
            localStorage.setItem('fluentge-premium', 'true');
          }
        } catch(e) {}
      }

      var selectedPlan = 'yearly';
      window.openPaymentModal = function(plan) {
        selectedPlan = plan;
        var badge = document.getElementById('modal-plan-badge');
        badge.textContent = plan === 'yearly' ? 'წლიური — $79.99/წელი' : 'თვიური — $9.99/თვე';
        document.getElementById('payment-overlay').classList.add('show');
      };
      window.closePaymentModal = function() {
        document.getElementById('payment-overlay').classList.remove('show');
      };
      document.getElementById('payment-overlay').addEventListener('click', function(e) {
        if (e.target === this) closePaymentModal();
      });
      document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closePaymentModal(); });

      window.handlePayment = function(method) {
        closePaymentModal();
        var plan = selectedPlan === 'yearly' ? '$79.99/წელი' : '$9.99/თვე';
        var msg = method === 'stripe'
          ? '💳 ბარათით გადახდა მალე ჩაირთვება!<br><br>ამჟამად დაგვიკავშირდი:<br>📧 <strong>tokakhozre@gmail.com</strong>'
          : '🏦 ქართული ბანკით გადახდა მალე ჩაირთვება!<br><br>ამჟამად დაგვიკავშირდი:<br>📧 <strong>tokakhozre@gmail.com</strong>';
        var toast = document.createElement('div');
        toast.style.cssText = 'position:fixed;bottom:2rem;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,#818cf8,#6366f1);color:white;padding:1.25rem 1.5rem;border-radius:1rem;font-size:0.85rem;z-index:200;max-width:90%;text-align:center;line-height:1.6;box-shadow:0 8px 32px rgba(99,102,241,0.3);animation:payModalIn 0.3s ease;';
        toast.innerHTML = msg;
        document.body.appendChild(toast);
        setTimeout(function() { toast.style.opacity = '0'; toast.style.transition = 'opacity 0.5s'; }, 6000);
        setTimeout(function() { toast.remove(); }, 6500);
      };
    })();
  </script>
</Layout>
