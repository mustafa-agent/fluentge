---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="დასრულებული გაკვეთილები — FluentGe">
  <section class="max-w-2xl mx-auto px-4 py-12">
    <a href="/dashboard/" class="text-[#6B6B65] hover:text-[#C8C8C0] text-sm mb-4 inline-block">← დეშბორდი</a>
    <h1 class="font-['Playfair_Display',serif] text-2xl font-bold mb-2">📖 დასრულებული გაკვეთილები</h1>
    <p class="text-[#A0A09A] text-sm mb-6">სულ: <span id="count" class="font-bold text-[#C8C8C0]">0</span> გაკვეთილი</p>
    
    <div id="list" class="space-y-2"></div>
    <div id="empty" class="hidden text-center py-12">
      <p class="text-4xl mb-3">📖</p>
      <p class="text-[#6B6B65]">ჯერ არ გაქვს დასრულებული გაკვეთილები</p>
      <p class="text-[#5B5B55] text-sm mt-2">გაკვეთილის სავარჯიშოები რომ დაასრულებ, ავტომატურად აღირიცხება</p>
      <a href="/grammar/" class="inline-block mt-4 bg-[#5B7F5E] text-white px-6 py-2 rounded-xl text-sm font-semibold hover:bg-[#4a6b4d]">გრამატიკის გვერდზე გადასვლა</a>
    </div>
  </section>

  <script is:inline>
    (function() {
      var items = JSON.parse(localStorage.getItem('fluentge-grammar-completed') || '[]');
      document.getElementById('count').textContent = items.length;
      if (items.length === 0) {
        document.getElementById('empty').classList.remove('hidden');
      } else {
        var list = document.getElementById('list');
        items.forEach(function(slug) {
          var div = document.createElement('div');
          div.className = 'bg-[#242426] border border-[#2E2E30] rounded-xl p-4 flex items-center gap-3';
          div.innerHTML = '<span class="text-green-400">✅</span><a href="/grammar/' + slug + '/" class="text-sm hover:text-[#C8C8C0] transition-colors">' + slug.replace(/-/g, ' ') + '</a>';
          list.appendChild(div);
        });
      }
    })();
  </script>
</Layout>
