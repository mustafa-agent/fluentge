---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="ფრაზები — FluentGe">
  <section class="max-w-2xl mx-auto px-4 py-12">
    <a href="/dashboard/" class="text-[#6B6B65] hover:text-[#C8C8C0] text-sm mb-4 inline-block">← დეშბორდი</a>
    <h1 class="font-['Playfair_Display',serif] text-2xl font-bold mb-2">💬 ფრაზები</h1>
    
    <div class="text-center py-12">
      <p class="text-4xl mb-3">💬</p>
      <p class="text-[#A0A09A]">ფრაზების პროგრესი ავტომატურად აღირიცხება</p>
      <p class="text-[#5B5B55] text-sm mt-2">მოუსმინე და ივარჯიშე ფრაზების გვერდზე</p>
      <a href="/phrases/" class="inline-block mt-4 bg-[#5B7F5E] text-white px-6 py-2 rounded-xl text-sm font-semibold hover:bg-[#4a6b4d]">ფრაზების გვერდზე გადასვლა</a>
    </div>
  </section>
</Layout>
