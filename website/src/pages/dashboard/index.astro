---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="бғ“бғ”бғЁбғ‘бғқбғ бғ“бғҳ вҖ” FluentGe">
  <section class="max-w-2xl mx-auto px-4 py-12">
    <h1 class="font-['Playfair_Display',serif] text-3xl font-bold mb-2 text-center">рҹ“Ҡ бғ“бғ”бғЁбғ‘бғқбғ бғ“бғҳ</h1>
    <p class="text-[#A0A09A] text-center mb-10">бғЁбғ”бғңбғҳ бғЎбғ¬бғҗбғ•бғҡбғҳбғЎ бғЎбғўбғҗбғўбғҳбғЎбғўбғҳбғҷбғҗ</p>

    <!-- Continue Where You Left Off -->
    <div id="continue-card" class="hidden mb-8">
      <div class="bg-gradient-to-r from-sky-500/10 to-indigo-500/10 border border-sky-500/20 rounded-2xl p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-xl">рҹҡҖ</span>
          <h2 class="font-bold text-lg">бғ’бғҗбғҗбғ’бғ бғ«бғ”бғҡбғ” бғЎбғ¬бғҗбғ•бғҡбғҗ</h2>
        </div>
        <div id="continue-suggestions" class="space-y-2"></div>
      </div>
    </div>

    <!-- Quick Start (shown when no progress yet) -->
    <div id="quick-start" class="hidden mb-8">
      <div class="bg-gradient-to-r from-green-500/10 to-emerald-500/10 border border-green-500/20 rounded-2xl p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-xl">рҹ‘Ӣ</span>
          <h2 class="font-bold text-lg">бғ“бғҗбғҳбғ¬бғ§бғ” бғЎбғ¬бғҗбғ•бғҡбғҗ!</h2>
        </div>
        <p class="text-[#A0A09A] text-sm mb-3">бғҗбғҳбғ бғ©бғҳбғ” бғЎбғҗбғ“бғҗбғң бғ’бғҳбғңбғ“бғҗ бғ“бғҗбғ¬бғ§бғ”бғ‘бғҗ:</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
          <a href="/flashcards/" class="flex items-center gap-2 bg-[#242426] hover:bg-[#2E2E30] rounded-xl px-4 py-3 transition-colors">
            <span>рҹ“қ</span><span class="text-sm font-medium">бғӨбғҡбғ”бғЁбғҘбғҗбғ бғ“бғ”бғ‘бғҳ</span>
          </a>
          <a href="/grammar/to-be/" class="flex items-center gap-2 bg-[#242426] hover:bg-[#2E2E30] rounded-xl px-4 py-3 transition-colors">
            <span>рҹ“–</span><span class="text-sm font-medium">бғ’бғ бғҗбғӣбғҗбғўбғҳбғҷбғҗ A1</span>
          </a>
          <a href="/games" class="flex items-center gap-2 bg-[#242426] hover:bg-[#2E2E30] rounded-xl px-4 py-3 transition-colors">
            <span>рҹҺ®</span><span class="text-sm font-medium">бғ—бғҗбғӣбғҗбғЁбғ”бғ‘бғҳ</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Vocabulary Size Tracker -->
    <div id="vocab-tracker" class="mb-8">
      <h2 class="font-bold text-lg mb-4 flex items-center gap-2">рҹ“– бғ©бғ”бғӣбғҳ бғҡбғ”бғҘбғЎбғҳбғҷбғҗ</h2>
      <div class="bg-gradient-to-br from-emerald-500/10 to-sky-500/10 border border-emerald-500/20 rounded-2xl p-5">
        <div class="flex items-center gap-6">
          <!-- SVG Progress Ring -->
          <div class="relative flex-shrink-0">
            <svg width="100" height="100" viewBox="0 0 100 100" class="transform -rotate-90">
              <circle cx="50" cy="50" r="42" fill="none" stroke="currentColor" stroke-width="8" class="text-[#2E2E30]" />
              <circle id="vocab-ring-mastered" cx="50" cy="50" r="42" fill="none" stroke="#22c55e" stroke-width="8" stroke-linecap="round" stroke-dasharray="264" stroke-dashoffset="264" class="transition-all duration-1000" />
              <circle id="vocab-ring-learning" cx="50" cy="50" r="42" fill="none" stroke="#f59e0b" stroke-width="8" stroke-linecap="round" stroke-dasharray="264" stroke-dashoffset="264" class="transition-all duration-1000" />
            </svg>
            <div class="absolute inset-0 flex flex-col items-center justify-center">
              <span id="vocab-pct" class="text-xl font-extrabold text-[var(--color-text)]">0%</span>
              <span class="text-[9px] text-[var(--color-text-muted)]">бғңбғҗбғЎбғ¬бғҗбғ•бғҡбғҳ</span>
            </div>
          </div>
          <!-- Stats -->
          <div class="flex-1 space-y-2">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <span class="w-3 h-3 rounded-full bg-green-500 inline-block"></span>
                <span class="text-sm text-[var(--color-text-muted)]">бғҗбғ—бғ•бғҳбғЎбғ”бғ‘бғЈбғҡбғҳ</span>
              </div>
              <span id="vocab-mastered" class="text-sm font-bold text-green-400">0</span>
            </div>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
