      </div>
      <div class="bg-[#242426] border border-[#2E2E30] rounded-2xl p-6 text-center">
        <p class="text-3xl font-bold" id="stat-podcasts">0</p>
        <p class="text-[#6B6B65] text-sm mt-1">бғӣбғқбғЎбғӣбғ”бғңбғҳбғҡбғҳ бғһбғқбғ“бғҷбғҗбғЎбғўбғ”бғ‘бғҳ</p>
      </div>
      <div class="bg-[#242426] border border-[#2E2E30] rounded-2xl p-6 text-center">
        <p class="text-3xl font-bold" id="stat-cards">0</p>
        <p class="text-[#6B6B65] text-sm mt-1">бғңбғҗбғЎбғ¬бғҗбғ•бғҡбғҳ бғЎбғҳбғўбғ§бғ•бғ”бғ‘бғҳ</p>
      </div>
    </div>

    <!-- Game Stats Section -->
    <div class="mb-8">
      <h2 class="font-bold text-lg mb-4 flex items-center gap-2">рҹҺ® бғ—бғҗбғӣбғҗбғЁбғ”бғ‘бғҳбғЎ бғЎбғўбғҗбғўбғҳбғЎбғўбғҳбғҷбғҗ</h2>
      <div class="grid grid-cols-2 gap-3 mb-4">
        <div class="bg-gradient-to-br from-indigo-500/20 to-purple-500/20 border border-indigo-500/30 rounded-2xl p-4 text-center">
          <p class="text-2xl font-bold text-indigo-400" id="game-today">0</p>
          <p class="text-[#6B6B65] text-xs mt-1">бғ“бғҰбғ”бғЎ бғңбғҗбғ—бғҗбғӣбғҗбғЁбғ”бғ‘бғҳ</p>
        </div>
        <div class="bg-gradient-to-br from-purple-500/20 to-pink-500/20 border border-purple-500/30 rounded-2xl p-4 text-center">
          <p class="text-2xl font-bold text-purple-400" id="game-total">0</p>
          <p class="text-[#6B6B65] text-xs mt-1">бғЎбғЈбғҡ бғңбғҗбғ—бғҗбғӣбғҗбғЁбғ”бғ‘бғҳ</p>
        </div>
        <div class="bg-gradient-to-br from-yellow-500/20 to-amber-500/20 border border-yellow-500/30 rounded-2xl p-4 text-center">
          <p class="text-2xl font-bold text-yellow-400" id="game-xp">+0</p>
          <p class="text-[#6B6B65] text-xs mt-1">бғ“бғҰбғ”бғЎ XP бғ—бғҗбғӣбғҗбғЁбғ”бғ‘бғҳбғ“бғҗбғң</p>
        </div>
        <div class="bg-gradient-to-br from-emerald-500/20 to-teal-500/20 border border-emerald-500/30 rounded-2xl p-4 text-center">
          <p class="text-2xl font-bold text-emerald-400" id="game-level">Lv.1</p>
          <p class="text-[#6B6B65] text-xs mt-1">бғӣбғҳбғӣбғ“бғҳбғңбғҗбғ бғ” бғ“бғқбғңбғ”</p>
        </div>
      </div>
      <!-- XP Progress Bar -->
      <div class="bg-[#242426] border border-[#2E2E30] rounded-xl p-4 mb-3">
        <div class="flex justify-between text-sm mb-2">
          <span id="game-level-label" class="text-[#A0A09A]">бғ“бғқбғңбғ” 1</span>
          <span id="game-xp-progress-text" class="text-[#A0A09A]">0/200 XP</span>
        </div>
        <div class="w-full bg-[#1C1C1E] rounded-full h-3">
          <div id="game-xp-bar" class="bg-gradient-to-r from-indigo-500 to-purple-500 h-3 rounded-full transition-all" style="width:0%"></div>
        </div>
      </div>
      <a href="/games/" class="block w-full text-center py-3 bg-indigo-600 hover:bg-indigo-700 border-b-4 border-indigo-700 active:border-b-0 rounded-xl font-bold text-white transition-all text-sm">
        рҹҺ® бғ—бғҗбғӣбғҗбғЁбғ”бғ‘бғҳбғЎ бғ’бғ•бғ”бғ бғ“бғ–бғ” бғ’бғҗбғ“бғҗбғЎбғ•бғҡбғҗ
      </a>
    </div>

    <div class="space-y-3">
      <a href="/dashboard/phrases/" class="flex items-center justify-between bg-[#242426] border border-[#2E2E30] rounded-xl p-4 hover:bg-[#2E2E30] transition-colors">
        <div class="flex items-center gap-3">
          <span class="text-2xl">рҹ’¬</span>
          <div>
            <p class="font-semibold">бғӨбғ бғҗбғ–бғ”бғ‘бғҳ</p>
            <p class="text-[#6B6B65] text-xs">бғңбғҗбғЎбғ¬бғҗбғ•бғҡбғҳ бғӨбғ бғҗбғ–бғ”бғ‘бғҳбғЎ бғЎбғҳбғҗ</p>
          </div>
        </div>
        <span class="text-[#6B6B65]">вҶ’</span>
      </a>

      <a href="/dashboard/grammar/" class="flex items-center justify-between bg-[#242426] border border-[#2E2E30] rounded-xl p-4 hover:bg-[#2E2E30] transition-colors">
        <div class="flex items-center gap-3">
          <span class="text-2xl">рҹ“–</span>
          <div>
            <p class="font-semibold">бғ’бғ бғҗбғӣбғҗбғўбғҳбғҷбғҗ</p>
            <p class="text-[#6B6B65] text-xs">бғңбғҗбғЎбғ¬бғҗбғ•бғҡбғҳ бғ’бғҗбғҷбғ•бғ”бғ—бғҳбғҡбғ”бғ‘бғҳбғЎ бғЎбғҳбғҗ</p>
          </div>
        </div>
        <span class="text-[#6B6B65]">вҶ’</span>
      </a>

      <a href="/dashboard/podcasts/" class="flex items-center justify-between bg-[#242426] border border-[#2E2E30] rounded-xl p-4 hover:bg-[#2E2E30] transition-colors">
        <div class="flex items-center gap-3">
          <span class="text-2xl">рҹҺ§</span>
          <div>
            <p class="font-semibold">бғһбғқбғ“бғҷбғҗбғЎбғўбғ”бғ‘бғҳ</p>
            <p class="text-[#6B6B65] text-xs">бғӣбғқбғЎбғӣбғ”бғңбғҳбғҡбғҳ бғһбғқбғ“бғҷбғҗбғЎбғўбғ”бғ‘бғҳбғЎ бғЎбғҳбғҗ</p>
          </div>
        </div>
        <span class="text-[#6B6B65]">вҶ’</span>
      </a>

      <a href="/dashboard/cards/" class="flex items-center justify-between bg-[#242426] border border-[#2E2E30] rounded-xl p-4 hover:bg-[#2E2E30] transition-colors">
        <div class="flex items-center gap-3">
          <span class="text-2xl">рҹ“қ</span>
          <div>
            <p class="font-semibold">бғӨбғҡбғ”бғЁбғҘбғҗбғ бғ“бғ”бғ‘бғҳ</p>
            <p class="text-[#6B6B65] text-xs">бғЎбғҳбғўбғ§бғ•бғ”бғ‘бғҳбғЎ бғЎбғўбғҗбғўбғҳбғЎбғўбғҳбғҷбғҗ</p>
          </div>
        </div>
        <span class="text-[#6B6B65]">вҶ’</span>
      </a>
    </div>
  </section>

  <script is:inline>
    (function() {
      var TOTAL_WORDS = 26595;
      var SRS_KEY_PREFIX = 'fluentge-srs-';

      // --- Vocabulary Size Tracker ---
      var mastered = 0, learning = 0;
      var allSRSWords = new Set();
      var keys = Object.keys(localStorage);
      for (var k = 0; k < keys.length; k++) {
        var key = keys[k];
        if (key.indexOf(SRS_KEY_PREFIX) !== 0) continue;
        try {
          var store = JSON.parse(localStorage.getItem(key) || '{}');
          var words = Object.keys(store);
          for (var w = 0; w < words.length; w++) {
            var d = store[words[w]];
            allSRSWords.add(words[w]);
            if (d.repetitions >= 3) mastered++;
            else if (d.repetitions >= 1) learning++;
          }
        } catch(e) {}
      }
      // Also count from fluentge_progress (classic study mode)
      var classicProgress = {};
      try { classicProgress = JSON.parse(localStorage.getItem('fluentge_progress') || '{}'); } catch(e) {}
      var classicKeys = Object.keys(classicProgress);
      for (var c = 0; c < classicKeys.length; c++) {
        var ck = classicKeys[c];
        var base = ck.replace(/_enka$/, '').replace(/_kaen$/, '').replace(/_mixed$/, '');
        if (!allSRSWords.has(base)) {
          allSRSWords.add(base);
          var cp = classicProgress[ck];
          if (cp && cp.repetitions >= 3) mastered++;
          else if (cp && cp.repetitions >= 1) learning++;
        }
      }
      var totalSeen = allSRSWords.size;
      var newWords = TOTAL_WORDS - totalSeen;
      var pct = TOTAL_WORDS > 0 ? Math.round((mastered / TOTAL_WORDS) * 100) : 0;

      document.getElementById('vocab-mastered').textContent = mastered;
      document.getElementById('vocab-learning').textContent = learning;
      document.getElementById('vocab-new').textContent = newWords > 0 ? newWords : 0;
      document.getElementById('vocab-total').textContent = TOTAL_WORDS;
      document.getElementById('vocab-pct').textContent = pct + '%';

      // Animate SVG rings (circumference = 2*PI*42 вүҲ 264)
      var circ = 264;
      var masteredPct = mastered / TOTAL_WORDS;
      var learningPct = learning / TOTAL_WORDS;
      setTimeout(function() {
        document.getElementById('vocab-ring-mastered').setAttribute('stroke-dashoffset', String(circ - (circ * masteredPct)));
        var learningRing = document.getElementById('vocab-ring-learning');
        // Learning ring starts where mastered ends
        learningRing.setAttribute('stroke-dashoffset', String(circ - (circ * learningPct)));
        learningRing.setAttribute('stroke-dasharray', circ * learningPct + ' ' + circ);
        // Rotate learning ring to start after mastered
        learningRing.style.transform = 'rotate(' + (masteredPct * 360) + 'deg)';
        learningRing.style.transformOrigin = '50px 50px';
      }, 100);

      // --- Recommended For You ---
      var deckMeta = [
        {id:'top-2000',name:'бғўбғқбғһ 2000 бғЎбғҳбғўбғ§бғ•бғҗ',icon:'вӯҗ',cards:1870},
        {id:'greetings',name:'бғӣбғҳбғЎбғҗбғҡбғӣбғ”бғ‘бғ”бғ‘бғҳ',icon:'рҹ‘Ӣ',cards:200},
        {id:'numbers',name:'бғ бғҳбғӘбғ®бғ•бғ”бғ‘бғҳ бғ“бғҗ бғ“бғ бғқ',icon:'рҹ”ў',cards:200},
        {id:'family',name:'бғқбғҜбғҗбғ®бғҳ бғ“бғҗ бғ®бғҗбғҡбғ®бғҳ',icon:'рҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§вҖҚрҹ‘Ұ',cards:200},
        {id:'food',name:'бғЎбғҗбғҷбғ•бғ”бғ‘бғҳ бғ“бғҗ бғҷбғЈбғҡбғҳбғңбғҗбғ бғҳбғҗ',icon:'рҹҚі',cards:50},
        {id:'home',name:'бғЎбғҗбғ®бғҡбғҳ',icon:'рҹҸ ',cards:200},
        {id:'travel',name:'бғӣбғқбғ’бғ–бғҗбғЈбғ бғқбғ‘бғҗ',icon:'вңҲпёҸ',cards:50},
        {id:'work',name:'бғЎбғҗбғӣбғЈбғЁбғҗбғқ бғ“бғҗ бғ‘бғҳбғ–бғңбғ”бғЎбғҳ',icon:'рҹ’ј',cards:50},
        {id:'health',name:'бғҜбғҗбғңбғӣбғ бғ—бғ”бғҡбғқбғ‘бғҗ',icon:'рҹҸҘ',cards:200},
        {id:'technology',name:'бғўбғ”бғҘбғңбғқбғҡбғқбғ’бғҳбғҗ',icon:'рҹ’»',cards:200},
        {id:'emotions',name:'бғ”бғӣбғқбғӘбғҳбғ”бғ‘бғҳ',icon:'рҹҳҠ',cards:200},
        {id:'education',name:'бғ’бғҗбғңбғҗбғ—бғҡбғ”бғ‘бғҗ',icon:'рҹ“ҡ',cards:200},
        {id:'verbs',name:'бғ®бғЁбғҳбғ бғҳ бғ–бғӣбғңбғ”бғ‘бғҳ',icon:'рҹҸғ',cards:200},
        {id:'animals',name:'бғӘбғ®бғқбғ•бғ”бғҡбғ”бғ‘бғҳ',icon:'рҹҗҫ',cards:200},
        {id:'sports',name:'бғЎбғһбғқбғ бғўбғҳ',icon:'вҡҪ',cards:50}
      ];
      var recs = [];
      var now = Date.now();

      // 1. Decks with due SRS reviews (highest priority)
      for (var i = 0; i < deckMeta.length && recs.length < 2; i++) {
        var dm = deckMeta[i];
        try {
          var srsStore = JSON.parse(localStorage.getItem(SRS_KEY_PREFIX + dm.id) || '{}');
          var due = 0;
          var srsWords = Object.values(srsStore);
          for (var j = 0; j < srsWords.length; j++) {
            if (srsWords[j].nextReview <= now && srsWords[j].repetitions > 0) due++;
          }
          if (due > 0) {
            recs.push({
              icon: 'рҹ””',
              text: dm.icon + ' ' + dm.name + ' вҖ” ' + due + ' бғЎбғҳбғўбғ§бғ•бғҗ бғ’бғҗбғ“бғҗбғЎбғҗбғ®бғ”бғ“бғҳбғҗ',
              href: '/flashcards/#study/' + dm.id + '/srs',
              color: 'amber',
              priority: 1
            });
          }
        } catch(e) {}
      }

      // 2. Partially studied decks (started but <50% done)
      for (var i = 0; i < deckMeta.length && recs.length < 4; i++) {
        var dm = deckMeta[i];
        try {
          var srsStore = JSON.parse(localStorage.getItem(SRS_KEY_PREFIX + dm.id) || '{}');
          var studied = Object.keys(srsStore).length;
          if (studied > 0 && studied < dm.cards * 0.5) {
            var pctDone = Math.round((studied / dm.cards) * 100);
            // Don't duplicate if already in recs
            if (!recs.some(function(r) { return r.href.indexOf(dm.id) > -1; })) {
              recs.push({
                icon: 'рҹ“Ҳ',
                text: dm.icon + ' ' + dm.name + ' вҖ” ' + pctDone + '% бғ’бғҗбғ•бғҡбғҳбғҡбғҳ, бғ’бғҗбғҗбғ’бғ бғ«бғ”бғҡбғ”!',
                href: '/flashcards/#study/' + dm.id + '/srs',
                color: 'sky',
                priority: 2
              });
            }
          }
        } catch(e) {}
      }

      // 3. Suggest unstudied beginner decks
      var beginnerDecks = ['greetings','numbers','family','food','home'];
      for (var i = 0; i < beginnerDecks.length && recs.length < 5; i++) {
        var bid = beginnerDecks[i];
        var srsData = localStorage.getItem(SRS_KEY_PREFIX + bid);
        if (!srsData || Object.keys(JSON.parse(srsData || '{}')).length === 0) {
          var meta = deckMeta.find(function(d) { return d.id === bid; });
          if (meta && !recs.some(function(r) { return r.href.indexOf(bid) > -1; })) {
            recs.push({
              icon: 'рҹҶ•',
              text: meta.icon + ' ' + meta.name + ' вҖ” бғ“бғҗбғҳбғ¬бғ§бғ” бғҗбғ®бғҗбғҡбғҳ бғ—бғ”бғӣбғҗ!',
              href: '/flashcards/#deck/' + bid,
              color: 'green',
              priority: 3
            });
          }
        }
      }

      // Show max 3 recommendations
      recs = recs.slice(0, 3);
      if (recs.length > 0) {
        var section = document.getElementById('recommended-section');
        var list = document.getElementById('recommended-list');
        section.classList.remove('hidden');
        var colorMap = {amber:'from-amber-500/10 to-yellow-500/10 border-amber-500/20', sky:'from-sky-500/10 to-blue-500/10 border-sky-500/20', green:'from-green-500/10 to-emerald-500/10 border-green-500/20'};
        recs.forEach(function(r) {
          var a = document.createElement('a');
          a.href = r.href;
          var cls = colorMap[r.color] || colorMap.sky;
          a.className = 'flex items-center gap-3 bg-gradient-to-r ' + cls + ' border rounded-xl px-4 py-3 transition-all hover:translate-x-1 hover:shadow-lg';
          a.innerHTML = '<span class="text-lg">' + r.icon + '</span><span class="text-sm font-medium flex-1">' + r.text + '</span><span class="text-[var(--color-text-muted)]">вҶ’</span>';
          list.appendChild(a);
        });
      }

      const phrases = JSON.parse(localStorage.getItem('fluentge-learned-phrases') || '[]');
      const grammar = JSON.parse(localStorage.getItem('fluentge-learned-grammar') || '[]');
      const podcasts = JSON.parse(localStorage.getItem('fluentge-learned-podcasts') || '[]');
      // Count unique base words from card progress
      var cardProgress = {};
      try { cardProgress = JSON.parse(localStorage.getItem('fluentge-card-progress') || '{}'); } catch(e) {}
      var baseWords = {};
      Object.keys(cardProgress).forEach(function(key) {
        var base = key.replace(/_enka$/, '').replace(/_kaen$/, '').replace(/_mixed$/, '');
        baseWords[base] = true;
      });
      var wordCount = totalSeen || Object.keys(baseWords).length;
      document.getElementById('stat-phrases').textContent = phrases.length;
      document.getElementById('stat-grammar').textContent = grammar.length;
      document.getElementById('stat-podcasts').textContent = podcasts.length;
      document.getElementById('stat-cards').textContent = wordCount;

      // Game stats
      var gamesPlayed = parseInt(localStorage.getItem('gamesPlayed') || '0', 10);
      var totalXP = parseInt(localStorage.getItem('totalXP') || '0', 10);
      var todayStr = new Date().toDateString();
      var todayGamesCount = 0, todayGameXP = 0;
      try {
        var tg = JSON.parse(localStorage.getItem('todayGames') || '{}');
        if (tg.date === todayStr) { todayGamesCount = tg.count || 0; todayGameXP = tg.xp || 0; }
      } catch(e) {}
      var gameLevel = Math.floor(totalXP / 200) + 1;
      var xpInLevel = totalXP - (gameLevel - 1) * 200;
      document.getElementById('game-today').textContent = todayGamesCount;
      document.getElementById('game-total').textContent = gamesPlayed;
      document.getElementById('game-xp').textContent = '+' + todayGameXP;
      document.getElementById('game-level').textContent = 'Lv.' + gameLevel;
      document.getElementById('game-level-label').textContent = 'бғ“бғқбғңбғ” ' + gameLevel;
      document.getElementById('game-xp-progress-text').textContent = xpInLevel + '/200 XP';
      document.getElementById('game-xp-bar').style.width = Math.min(100, (xpInLevel / 200) * 100) + '%';

      // Continue where you left off logic
      var totalProgress = phrases.length + grammar.length + podcasts.length + wordCount;
      var suggestions = [];

      // Grammar progression: suggest next unlearned lesson
      var grammarOrder = [
        {slug:'to-be', title:'бғ–бғӣбғңбғҗ "to be"'},
        {slug:'articles', title:'бғҗбғ бғўбғҳбғҷбғҡбғ”бғ‘бғҳ (a/an/the)'},
        {slug:'plural-nouns', title:'бғӣбғ бғҗбғ•бғҡбғқбғ‘бғҳбғ—бғҳ бғ бғҳбғӘбғ®бғ•бғҳ'}
      ];
      var nextGrammar = grammarOrder.find(function(g) {
        return !grammar.some(function(learned) { return learned.toLowerCase().includes(g.slug.replace('-',' ')); });
      });
      if (nextGrammar) {
        suggestions.push({
          icon: 'рҹ“–',
          text: 'бғ’бғ бғҗбғӣбғҗбғўбғҳбғҷбғҗ: ' + nextGrammar.title,
          href: '/grammar/' + nextGrammar.slug + '/',
          color: 'green'
        });
      }

      // Flashcards: always a good suggestion
      if (wordCount > 0) {
        suggestions.push({
          icon: 'рҹ“қ',
          text: 'бғ’бғҗбғҗбғ’бғ бғ«бғ”бғҡбғ” бғӨбғҡбғ”бғЁбғҘбғҗбғ бғ“бғ”бғ‘бғҳ вҖ” ' + wordCount + ' бғЎбғҳбғўбғ§бғ•бғҗ бғңбғҗбғЎбғ¬бғҗбғ•бғҡбғҳ',
          href: '/flashcards/',
          color: 'sky'
        });
      } else {
        suggestions.push({
          icon: 'рҹ“қ',
          text: 'бғ“бғҗбғҳбғ¬бғ§бғ” бғӨбғҡбғ”бғЁбғҘбғҗбғ бғ“бғ”бғ‘бғҳ вҖ” бғҳбғЎбғ¬бғҗбғ•бғҡбғ” бғҗбғ®бғҗбғҡбғҳ бғЎбғҳбғўбғ§бғ•бғ”бғ‘бғҳ',
          href: '/flashcards/',
          color: 'sky'
        });
      }

      // Phrases: suggest if not many learned
      if (phrases.length < 50) {
        suggestions.push({
          icon: 'рҹ’¬',
          text: 'бғҳбғЎбғ¬бғҗбғ•бғҡбғ” бғ§бғқбғ•бғ”бғҡбғ“бғҰбғҳбғЈбғ бғҳ бғӨбғ бғҗбғ–бғ”бғ‘бғҳ',
          href: '/phrases/',
          color: 'indigo'
        });
      }

      // Games: suggest for variety
      suggestions.push({
        icon: 'рҹҺ®',
        text: 'бғҳбғ—бғҗбғӣбғҗбғЁбғ” бғ“бғҗ бғҳбғЎбғ¬бғҗбғ•бғҡбғ” бғҳбғңбғ’бғҡбғҳбғЎбғЈбғ бғҳ',
        href: '/games',
        color: 'amber'
      });

      // Show max 3 suggestions
      suggestions = suggestions.slice(0, 3);

      if (totalProgress === 0) {
        document.getElementById('quick-start').classList.remove('hidden');
      } else {
        var card = document.getElementById('continue-card');
        var container = document.getElementById('continue-suggestions');
        card.classList.remove('hidden');
        suggestions.forEach(function(s) {
          var a = document.createElement('a');
          a.href = s.href;
          a.className = 'flex items-center gap-3 bg-[#242426] hover:bg-[#2E2E30] rounded-xl px-4 py-3 transition-all hover:translate-x-1';
          a.innerHTML = '<span class="text-lg">' + s.icon + '</span><span class="text-sm font-medium flex-1">' + s.text + '</span><span class="text-[#6B6B65]">вҶ’</span>';
          container.appendChild(a);
        });
      }
    })();
  </script>
</Layout>
