                <span class="text-sm text-[var(--color-text-muted)]">бғЎбғ¬бғҗбғ•бғҡбғҗбғЁбғҳ</span>
              </div>
              <span id="vocab-learning" class="text-sm font-bold text-amber-400">0</span>
            </div>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <span class="w-3 h-3 rounded-full bg-[#3E3E40] inline-block"></span>
                <span class="text-sm text-[var(--color-text-muted)]">бғҗбғ®бғҗбғҡбғҳ</span>
              </div>
              <span id="vocab-new" class="text-sm font-bold text-[var(--color-text-muted)]">0</span>
            </div>
            <div class="pt-1 border-t border-white/5 flex items-center justify-between">
              <span class="text-xs text-[var(--color-text-muted)]">бғЎбғЈбғҡ бғЎбғҳбғўбғ§бғ•бғ”бғ‘бғҳ</span>
              <span id="vocab-total" class="text-xs font-bold text-[var(--color-text)]">0</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Recommended For You -->
    <div id="recommended-section" class="mb-8 hidden">
      <h2 class="font-bold text-lg mb-4 flex items-center gap-2">рҹҺҜ бғ бғ”бғҷбғқбғӣбғ”бғңбғ“бғҗбғӘбғҳбғҗ бғЁбғ”бғңбғ—бғ•бғҳбғЎ</h2>
